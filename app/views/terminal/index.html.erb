 РќѕРќѕРЋЉ  РќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРќѕРќѕРЋЌРќѕРќѕРЋћРЋљРЋљРЋљРЋљРЋЮРќѕРќѕРЋЉ РќѕРќѕРЋћРЋЮРќѕРќѕРЋћРЋљРЋљРќѕРќѕРЋЌ   РЋџРЋљРЋљРќѕРќѕРЋћРЋљРЋљРЋЮРќѕРќѕРЋЉ   РќѕРќѕРЋЉ
 РќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРќѕРќѕРќѕРќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРќѕРќѕРќѕРЋћРЋЮ РќѕРќѕРќѕРќѕРќѕРќѕРЋћРЋЮ      РќѕРќѕРЋЉ   РќѕРќѕРЋЉ   РќѕРќѕРЋЉ
 РќѕРќѕРЋћРЋљРЋљРќѕРќѕРЋЉРќѕРќѕРЋћРЋљРЋљРќѕРќѕРЋЉРќѕРќѕРЋЉ     РќѕРќѕРЋћРЋљРќѕРќѕРЋЌ РќѕРќѕРЋћРЋљРЋљРќѕРќѕРЋЌ      РќѕРќѕРЋЉ   РЋџРќѕРќѕРЋЌ РќѕРќѕРЋћРЋЮ
 РќѕРќѕРЋЉ  РќѕРќѕРЋЉРќѕРќѕРЋЉ  РќѕРќѕРЋЉРЋџРќѕРќѕРќѕРќѕРќѕРќѕРЋЌРќѕРќѕРЋЉ  РќѕРќѕРЋЌРќѕРќѕРЋЉ  РќѕРќѕРЋЉ   РќѕРќѕРЋЌРќѕРќѕРЋЉ    РЋџРќѕРќѕРќѕРќѕРЋћРЋЮ
 РЋџРЋљРЋЮ  РЋџРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋЮ РЋџРЋљРЋљРЋљРЋљРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋЮРЋџРЋљРЋЮ  РЋџРЋљРЋЮ   РЋџРЋљРЋЮРЋџРЋљРЋЮ     РЋџРЋљРЋљРЋљРЋЮ
    </pre>

    <!-- Main Content Box -->
    <div style="border: 2px solid #a78bfa; background: #111; padding: 30px;">

      <h1 style="color: #fbbf24; font-size: 18px; text-align: center; margin: 0 0 10px 0; letter-spacing: 4px;">
        TERMINAL ACCESS CREDENTIALS
      </h1>

      <div style="border-top: 1px solid #a78bfa; border-bottom: 1px solid #a78bfa; padding: 10px 0; margin: 20px 0;">
        <p style="color: #9ca3af; font-size: 12px; text-align: center; margin: 0;">
          THE.CYBERPUL.SE // <%= Time.current.year + 100 %>
        </p>
      </div>

      <!-- Connection Info -->
      <div style="background: #1a1a1a; padding: 20px; margin: 20px 0; border-left: 3px solid #22d3ee;">
        <div style="margin-bottom: 15px;">
          <span style="color: #9ca3af; font-size: 12px;">Connection:</span>
          <br>
          <code style="color: #22d3ee; font-size: 16px; background: #222; padding: 5px 10px; display: inline-block; margin-top: 5px;">
            <%= @ssh_command %>
          </code>
        </div>

        <div>
          <span style="color: #9ca3af; font-size: 12px;">Password:</span>
          <br>
          <code style="color: #34d399; font-size: 24px; font-weight: bold; background: #222; padding: 8px 15px; display: inline-block; margin-top: 5px; letter-spacing: 2px;">
            <%= @password %>
          </code>
        </div>
      </div>

      <!-- Countdown Timer -->
      <div style="text-align: center; margin: 20px 0;">
        <span style="color: #9ca3af; font-size: 12px;">Credential rotation in:</span>
        <br>
        <span id="countdown" style="color: #fbbf24; font-size: 28px; font-weight: bold; letter-spacing: 3px;">
          <%= @countdown %>
        </span>
      </div>

      <!-- Divider with Quote -->
      <div style="border-top: 1px solid #333; padding-top: 20px; margin-top: 20px;">
        <p style="color: #6b7280; font-size: 11px; text-align: center; font-style: italic; margin: 0;">
          "GovCorp rotates access tokens daily.<br>
          The Fracture Network adapts."
        </p>
      </div>

    </div>

    <!-- Instructions -->
    <div style="margin-top: 20px; padding: 15px; background: #111; border: 1px solid #333;">
      <h2 style="color: #a78bfa; font-size: 14px; margin: 0 0 10px 0;">CONNECTION INSTRUCTIONS</h2>
      <ol style="color: #9ca3af; font-size: 12px; margin: 0; padding-left: 20px; line-height: 1.8;">
        <li>Open your terminal</li>
        <li>Run the connection command above</li>
        <li>Enter the password when prompted</li>
        <li>Navigate using the menu or type commands</li>
      </ol>
      <p style="color: #6b7280; font-size: 11px; margin: 15px 0 0 0;">
        Works with: Terminal.app, iTerm2, PuTTY, Windows Terminal, Termux, Mudlet, and of course good ol' bash (or zsh/fish/ksh/sh) in the terminal emulator of your choice
      </p>
    </div>

  </div>
</div>

<script>
  // Live countdown timer
  (function() {
    const nextRotation = new Date('<%= @next_rotation.iso8601 %>');
    const countdownEl = document.getElementById('countdown');

    function updateCountdown() {
      const now = new Date();
      const diff = nextRotation - now;

      if (diff <= 0) {
        // Reload page to get new password
        location.reload();
        return;
      }

      const hours = Math.floor(diff / (1000 * 60 * 60));
      const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((diff % (1000 * 60)) / 1000);

      countdownEl.textContent =
        String(hours).padStart(2, '0') + ':' +
        String(minutes).padStart(2, '0') + ':' +
        String(seconds).padStart(2, '0');
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
  })();
</script>
