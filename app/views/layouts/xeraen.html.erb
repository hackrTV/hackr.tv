<!DOCTYPE html>
<html lang="en-US">
  <head>
    <title>X E R A E N</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tuicss", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "default", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "xeraen", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "tuicss", "data-turbo-track": "reload", type: "module" %>
    <%= javascript_include_tag "audio_player", "data-turbo-track": "reload", type: "module" %>
    <%= vite_client_tag %>
    <%= vite_typescript_tag 'application.tsx' %>
  </head>

  <body class="black-168">
    <%= render "shared/header_menu" %>

    <a href="/xeraen">
      <%= image_tag "xeraen-logo-350.png", class: "mt-30 ml-5 mb-10" %>
    </a>

    <%= render "shared/footer_menu" %>

    <div id="main-content" class="ml-10 mb-20 pb-50">
      <%= yield %>
    </div>

  </body>
</html>
