<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "hackr.tv" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
    <link rel="manifest" href="/manifest.json">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tuicss", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "default", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "audio_player", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application" %>
    <%= javascript_include_tag "tuicss", "data-turbo-track": "reload", type: "module" %>
    <%= vite_client_tag %>
    <%= vite_typescript_tag 'application.tsx' %>

  </head>

  <body class="black-168">
    <div id="main-content">
      <%= yield %>
    </div>
  </body>
</html>
