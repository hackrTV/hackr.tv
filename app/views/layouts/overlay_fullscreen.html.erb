<!DOCTYPE html>
<html lang="en-US">
  <head>
    <title>hackr.tv Overlay</title>
    <meta name="viewport" content="width=1920, height=1080" />
    <meta name="robots" content="noindex, nofollow" />
    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>
    <%= stylesheet_link_tag "tuicss", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "overlay", "data-turbo-track": "reload" %>
  </head>

  <body class="overlay-fullscreen">
    <%= yield %>
    <%= javascript_include_tag "overlay", "data-turbo-track": "reload", type: "module" %>
  </body>
</html>
