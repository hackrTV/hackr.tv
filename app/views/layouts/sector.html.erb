<!DOCTYPE html>
<html lang="en-US">
  <head>
    <title>Sector X</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tuicss", "data-turbo-track": "reload" %>
