<!DOCTYPE html>
<html lang="en-US">
  <head>
    <title>hackr.tv</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tuicss", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "default", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "tuicss", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="black-168">
    <%= render "shared/header_menu_mobile" %>

    <br>
    <br>

    <div class="ml-10 pl-5 white-168-text">
      <%= link_to root_path do %>
        <pre id="greetings" style="font-size: 11px;">&nbsp;__  __                   __            ______  __  __
/\ \/\ \                 /\ \          /\__  _\/\ \/\ \
\ \ \_\ \     __      ___\ \ \/'\   _ _\/_/\ \/\ \ \ \ \
 \ \  _  \  /'__`\   /'___\ \ , &lt;  /\`'__\\ \ \ \ \ \ \ \
  \ \ \ \ \/\ \L\.\_/\ \__/\ \ \\`\\ \ \/ _\ \ \ \ \ \_/ \
   \ \_\ \_\ \__/.\_\ \____\\ \_\ \_\ \_\/\_\ \_\ \ `\___/
    \/_/\/_/\/__/\/_/\/____/ \/_/\/_/\/_/\/_/\/_/  `\/__/</pre>
      <% end %>
    </div>

    <br>

    <div class="tui-window ml-20 mb-20">
      <fieldset class="tui-fieldset">
        <legend>Menu</legend>
        <div class="mb-20 pl-5 pr-15">
          <%= link_to "Trackz", thecyberpulse_tracks_path, class: "tui-button" %>
          <%= link_to "Streamz", "https://www.youtube.com/watch?v=YgD4oNPpGv4&list=PLLRgY_tjdreyU4_WtrQnkZ6D8ur41GrpC", class: "tui-button", target: "_blank" %>
          <%= link_to "Vidz", "https://www.youtube.com/@TheCyberPulse/videos", class: "tui-button", target: "_blank" %>
        </div>
        <div class="mb-15 pl-5 pr-15">
          <%= link_to "Linkz", "#", class: "tui-button" %>
        </div>
      </fieldset>
    </div>

    <br>

    <div class="ml-10 mb-20 pb-50">
      <%= yield %>
    </div>

  </body>
</html>
