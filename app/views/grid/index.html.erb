<script src="https://cdn.jsdelivr.net/npm/@rails/actioncable@7.1.0/app/assets/javascripts/actioncable.min.js"></script>

<div style="max-width: 1000px; margin: 10px auto; background: #1a1a1a; color: #d0d0d0; padding: 10px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; padding-bottom: 8px; border-bottom: 1px solid #4b5563;">
    <div style="font-size: 0.9em;">
      <span style="color: #a78bfa; font-weight: bold;">THE PULSE GRID</span>
      <span style="color: #666; margin: 0 8px;">|</span>
      <span style="color: #e0e0e0;"><%= current_hackr.hackr_alias %></span>
      <% if current_hackr.admin? %>
        <a href="/root" style="color: #f87171; font-size: 0.85em; margin-left: 5px; text-decoration: none;">[ADMIN]</a>
      <% end %>
    </div>
    <div>
      <%= button_to "DISCONNECT", grid_disconnect_path, method: :delete, style: "background: #dc2626; color: white; border: none; padding: 4px 12px; font-size: 0.85em; cursor: pointer; border-radius: 3px;", data: { confirm: "Disconnect from THE PULSE GRID?" } %>
    </div>
  </div>

  <!-- Game Output Window -->
  <div id="game-output" style="font-family: monospace; font-size: 0.75em; line-height: 1.2; white-space: pre-wrap; height: 700px; overflow-y: auto; padding: 10px; background: #0d0d0d; color: #d0d0d0; border: 1px solid #4b5563; border-radius: 3px; margin-bottom: 8px;">
    <% if flash[:command_output] %>
      <%= flash[:command_output] %>
    <% elsif @current_room %>
      <div style="color: #a78bfa; font-size: 0.9em;">
════════════════════════════════════════════════════════════════
  WELCOME TO THE PULSE GRID
════════════════════════════════════════════════════════════════
Connection established. Type 'help' for commands.
════════════════════════════════════════════════════════════════
   !! <span style="color:#f87171;">WARNING</span> !!
     ~~ THE PULSE GRID IS IN PRE-ALPHA.
     ~~ FREQUENT DATABASE FLUSHES _WILL_ OCCUR!
     ~~ JUST RE-CREATE YOUR ACCOUNT IF YOU CANNOT LOGIN LATER
   !! <span style="color:#f87171;">WARNING</span> !!
════════════════════════════════════════════════════════════════
      </div>
      <%= Grid::CommandParser.new(current_hackr, "look").execute[:output] %>
    <% else %>
      <span style="color: #f87171;">ERROR: No current room assigned. Contact system admin.</span>
    <% end %>
  </div>

  <!-- Command Input -->
  <%= form_with url: grid_command_path, method: :post, id: "command-form" do |f| %>
    <div style="display: flex; gap: 8px; margin-bottom: 6px;">
      <%= f.text_field :input, placeholder: "Enter command (type 'help' for commands)", autofocus: true, autocomplete: "off", style: "flex: 1; background: #262626; color: #e0e0e0; border: 1px solid #4b5563; padding: 6px 10px; font-family: monospace; font-size: 0.9em; border-radius: 3px;" %>
      <%= f.submit "EXECUTE", style: "background: #7c3aed; color: white; border: none; padding: 6px 16px; font-size: 0.85em; cursor: pointer; border-radius: 3px; font-weight: bold;" %>
    </div>
  <% end %>
  <div style="font-size: 0.75em; color: #9ca3af; line-height: 1.3;">
    Commands: look, go [dir], take/drop [item], say [msg], talk/ask [npc], inventory, who, help, clear
    <span style="margin-left: 10px; color: #666;">|</span>
    <span style="margin-left: 10px;">↑/↓ for history</span>
  </div>

</div>

<script nonce="<%= content_security_policy_nonce %>">
  // Global variables for Action Cable
  let cable;
  let currentSubscription;
  let currentRoomId = <%= current_hackr.current_room&.id || 'null' %>;
  const currentHackr = '<%= current_hackr.hackr_alias %>';

  // Command history
  let commandHistory = [];
  let historyIndex = -1;
  let currentDraft = ''; // Store current input when navigating history

  // Load command history from sessionStorage
  try {
    const stored = sessionStorage.getItem('grid_command_history');
    if (stored) {
      commandHistory = JSON.parse(stored);
    }
  } catch (e) {
    console.log('Could not load command history');
  }

  // Helper function to save command to history
  function addToHistory(command) {
    if (!command || !command.trim()) return;

    // Don't add duplicate of last command
    if (commandHistory.length > 0 && commandHistory[commandHistory.length - 1] === command) {
      return;
    }

    commandHistory.push(command);

    // Limit history to 100 commands
    if (commandHistory.length > 100) {
      commandHistory.shift();
    }

    // Save to sessionStorage
    try {
      sessionStorage.setItem('grid_command_history', JSON.stringify(commandHistory));
    } catch (e) {
      console.log('Could not save command history');
    }

    // Reset history navigation
    historyIndex = -1;
    currentDraft = '';
  }

  // Helper function to get opposite direction
  function oppositeDirection(dir) {
    const opposites = {
      'north': 'south',
      'south': 'north',
      'east': 'west',
      'west': 'east',
      'up': 'down',
      'down': 'up'
    };
    return opposites[dir] || dir;
  }

  // Function to subscribe to GridChannel
  function subscribeToRoom() {
    // Unsubscribe from previous subscription if exists
    if (currentSubscription) {
      console.log("Unsubscribing from previous room");
      cable.subscriptions.remove(currentSubscription);
    }

    // Create new subscription
    currentSubscription = cable.subscriptions.create("GridChannel", {
      connected() {
        console.log("Connected to GridChannel for room " + currentRoomId);
      },

      disconnected() {
        console.log("Disconnected from GridChannel");
      },

      received(data) {
        console.log("Received Action Cable data:", data);

        // Don't show your own events
        if (data.hackr_alias === currentHackr) {
          console.log("Skipping own event");
          return;
        }

        const output = document.getElementById('game-output');
        const timestamp = new Date().toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit' });
        let message = '';

        // Handle different event types
        switch(data.type) {
          case 'say':
            console.log("Handling say event:", data.message);
            message = `\n<span style="color: #a78bfa;">[${data.hackr_alias}]</span>: ${data.message}`;
            break;

          case 'movement':
            // Check if hackr entered or left current room
            if (data.to_room_id === currentRoomId) {
              message = `\n<span style="color: #22d3ee;">[${timestamp}] ${data.hackr_alias} enters from the ${oppositeDirection(data.direction)}.</span>`;
            } else if (data.from_room_id === currentRoomId) {
              message = `\n<span style="color: #22d3ee;">[${timestamp}] ${data.hackr_alias} leaves to the ${data.direction}.</span>`;
            }
            break;

          case 'take':
            message = `\n<span style="color: #fbbf24;">[${timestamp}] ${data.hackr_alias} takes the ${data.item_name}.</span>`;
            break;

          case 'drop':
            message = `\n<span style="color: #fbbf24;">[${timestamp}] ${data.hackr_alias} drops the ${data.item_name}.</span>`;
            break;
        }

        // Append message if not empty
        if (message) {
          const messageDiv = document.createElement('div');
          messageDiv.innerHTML = message;
          output.appendChild(messageDiv);
          output.scrollTop = output.scrollHeight;
        }
      }
    });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', function() {
    // Create Action Cable consumer
    cable = ActionCable.createConsumer();

    // Subscribe to initial room
    subscribeToRoom();

    const inputField = document.querySelector('input[name="input"]');

    // Handle keyboard navigation for command history
    inputField.addEventListener('keydown', function(event) {
      // Arrow Up - go back in history
      if (event.key === 'ArrowUp') {
        event.preventDefault();

        if (commandHistory.length === 0) return;

        // Store current input as draft when starting to navigate
        if (historyIndex === -1) {
          currentDraft = inputField.value;
        }

        // Navigate backwards in history
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          const historyCommand = commandHistory[commandHistory.length - 1 - historyIndex];
          inputField.value = historyCommand;
        }
      }
      // Arrow Down - go forward in history
      else if (event.key === 'ArrowDown') {
        event.preventDefault();

        if (historyIndex === -1) return; // Not navigating history

        // Navigate forwards in history
        historyIndex--;

        if (historyIndex === -1) {
          // Restore the draft
          inputField.value = currentDraft;
        } else {
          const historyCommand = commandHistory[commandHistory.length - 1 - historyIndex];
          inputField.value = historyCommand;
        }
      }
    });

    // Handle form submission manually for AJAX
    document.getElementById('command-form').addEventListener('submit', function(event) {
      event.preventDefault(); // Prevent normal form submission

      const form = event.target;
      const output = document.getElementById('game-output');
      const command = inputField.value;

      // Add command to history
      if (command.trim()) {
        addToHistory(command.trim());
      }

      // Check if this is a clear command
      if (command.trim().toLowerCase() === 'clear' || command.trim().toLowerCase() === 'cls') {
        output.innerHTML = '';
        inputField.value = '';
        return;
      }

      // Echo the command in cyan
      if (command.trim()) {
        const commandEcho = document.createElement('div');
        commandEcho.innerHTML = `<span style="color: #22d3ee;">&gt; ${command}</span>`;
        output.appendChild(commandEcho);
      }

      // Get CSRF token
      const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

      // Submit via fetch
      fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
          'Accept': 'application/json'
        },
        body: JSON.stringify({ input: command })
      })
      .then(response => response.json())
      .then(data => {
        // Append the output (if not empty)
        if (data.output && data.output.trim()) {
          const resultDiv = document.createElement('div');
          resultDiv.textContent = data.output;
          resultDiv.style.marginBottom = '1em';
          output.appendChild(resultDiv);
        }

        // Auto-scroll to bottom
        output.scrollTop = output.scrollHeight;

        // Check if room changed and resubscribe if needed
        if (data.room_id && data.room_id !== currentRoomId) {
          console.log("Room changed from " + currentRoomId + " to " + data.room_id + " - resubscribing...");
          currentRoomId = data.room_id;
          subscribeToRoom();
        }

        // Clear input
        inputField.value = '';
        inputField.focus();
      })
      .catch(error => {
        console.error('Command execution failed:', error);
        const errorDiv = document.createElement('div');
        errorDiv.innerHTML = '<span style="color: #f87171;">Error: Command execution failed. Please try again.</span>';
        output.appendChild(errorDiv);
        output.scrollTop = output.scrollHeight;
      });
    });
  });
</script>
