<%
  max_items = settings['max_items'] || 10
  online_hackrs = GridHackr.where("last_activity_at > ?", 15.minutes.ago)
    .includes(:current_room)
    .order(last_activity_at: :desc)
    .limit(max_items)

  style = "left: #{scene_element.x}px; top: #{scene_element.y}px;"
  style += " width: #{scene_element.width}px;" if scene_element.width
  style += " height: #{scene_element.height}px;" if scene_element.height
  style += " z-index: #{scene_element.z_index};" if scene_element.z_index
%>
<div class="scene-element overlay-grid-activity" style="<%= style %>" data-element-type="grid_activity">
  <div class="tui-header">
    <span class="grid-activity-title">THE PULSE GRID</span>
    <span class="grid-activity-count">[<%= online_hackrs.count %> ONLINE]</span>
  </div>
  <div class="grid-online-list">
    <% online_hackrs.each do |hackr| %>
      <div class="grid-online-hackr">
        <span class="grid-hackr-name"><%= hackr.hackr_alias %></span>
        <% if hackr.current_room %>
          <span class="grid-hackr-location">@ <%= hackr.current_room.name %></span>
        <% end %>
      </div>
    <% end %>
    <% if online_hackrs.empty? %>
      <div class="grid-online-hackr">
        <span class="grid-hackr-name" style="color: var(--overlay-gray);">No hackrs connected</span>
      </div>
    <% end %>
  </div>
</div>
