<div class="tui-window cyan-168 white-text" style="max-width: 1200px;">
  <fieldset class="cyan-168-border">
    <legend class="center">hackr.fm :: RADIO</legend>

    <div>
      <h2 class="cyan-255-text" style="text-align: center; margin-bottom: 15px;">
        [:: RESISTANCE RADIO STATIONS ::]
      </h2>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
        <% @stations.each do |station| %>
          <% if station['slug'] == 'sector_x' %>
            <div class="tui-window white-text" style="background: #0d0d0d; border: 1px solid #444;">
              <fieldset style="border-color: #555;">
                <legend style="color: #14b8a6;"><%= station['name'] %></legend>

                <div style="padding: 15px;">
                  <p style="margin-bottom: 10px; color: #888;"><strong>Genre:</strong> <span style="color: #aaa;"><%= station['genre'] %></span></p>
                  <p style="margin-bottom: 15px; line-height: 1.6; color: #999;"><%= station['description'].gsub('2125', (Time.now.year + 100).to_s) %></p>

                  <% if station['stream_url'].present? %>
                    <button class="tui-button tune-in-btn"
                            data-stream-url="<%= station['stream_url'] %>"
                            data-station-name="<%= station['name'] %>"
                            data-station-genre="<%= station['genre'] %>"
                            style="width: 100%; background: #14b8a6; color: white;">
                      ► TUNE IN
                    </button>
                  <% else %>
                    <button class="tui-button" style="width: 100%; opacity: 0.5; cursor: not-allowed;" disabled>
                      [COMING SOON]
                    </button>
                  <% end %>
                </div>
              </fieldset>
            </div>
          <% else %>
            <div class="tui-window <%= station['color'] %> white-text">
              <fieldset class="<%= station['color'] %>-border">
                <legend><%= station['name'] %></legend>

                <div style="padding: 15px;">
                  <p style="margin-bottom: 10px;"><strong>Genre:</strong> <%= station['genre'] %></p>
                  <p style="margin-bottom: 15px; line-height: 1.6;"><%= station['description'].gsub('2125', (Time.now.year + 100).to_s) %></p>

                  <% if station['stream_url'].present? %>
                    <button class="tui-button tune-in-btn <%= station['color'] %>"
                            data-stream-url="<%= station['stream_url'] %>"
                            data-station-name="<%= station['name'] %>"
                            data-station-genre="<%= station['genre'] %>"
                            style="width: 100%;">
                      ► TUNE IN
                    </button>
                  <% else %>
                    <button class="tui-button" style="width: 100%; opacity: 0.5; cursor: not-allowed;" disabled>
                      [COMING SOON]
                    </button>
                  <% end %>
                </div>
              </fieldset>
            </div>
          <% end %>
        <% end %>
      </div>

      <div style="margin-top: 30px; padding: 20px; background: #1a1a1a; border: 1px solid #444;">
        <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: BROADCAST INFO ::]</h3>
        <p style="line-height: 1.6; color: #ccc;">
          hackr.fm Radio transmits 24/7 from undisclosed locations across THE PULSE GRID.
          Each station is a beacon of resistance, broadcasting truth through the digital noise.
          Select a station above to begin streaming.
        </p>
      </div>
    </div>
  </fieldset>
</div>

<!-- Radio Player -->
<div id="radio-player" style="position: fixed; bottom: 0; left: 0; right: 0; background: #0a0a0a; border-top: 2px solid #00d9ff; padding: 15px 20px; display: none; z-index: 1000;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 20px;">
      <button id="radio-stop-btn" class="tui-button" style="background: #00d9ff; color: #000; min-width: 80px; font-weight: bold;">
        ■ STOP
      </button>

      <div style="flex: 1;">
        <div style="margin-bottom: 5px;">
          <span style="color: #00d9ff; font-weight: bold;">● LIVE</span>
          <span style="color: #666; margin: 0 10px;">|</span>
          <span id="station-name" style="color: #00d9ff; font-weight: bold;">—</span>
        </div>
        <div>
          <span style="color: #888; font-size: 0.9em;">Genre: </span>
          <span id="station-genre" style="color: #aaa; font-size: 0.9em;">—</span>
        </div>
      </div>

      <div style="display: flex; align-items: center; gap: 10px;">
        <span style="color: #888; font-size: 0.9em;">Volume:</span>
        <input type="range" id="radio-volume-control" min="0" max="100" value="70"
               style="width: 100px; height: 6px; background: #333; border-radius: 3px; outline: none; -webkit-appearance: none;">
      </div>

      <button id="close-radio-btn" class="tui-button" style="background: #444; color: #aaa;">
        ✕
      </button>
    </div>
  </div>

  <audio id="radio-audio-element" preload="none"></audio>
</div>

<style>
#radio-volume-control::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 14px;
  height: 14px;
  background: #00d9ff;
  cursor: pointer;
  border-radius: 50%;
}

#radio-volume-control::-moz-range-thumb {
  width: 14px;
  height: 14px;
  background: #00d9ff;
  cursor: pointer;
  border-radius: 50%;
  border: none;
}
</style>

<script>
(function() {
  const radioPlayer = document.getElementById('radio-player');
  const radioAudio = document.getElementById('radio-audio-element');
  const stopBtn = document.getElementById('radio-stop-btn');
  const volumeControl = document.getElementById('radio-volume-control');
  const stationNameEl = document.getElementById('station-name');
  const stationGenreEl = document.getElementById('station-genre');
  const closeRadioBtn = document.getElementById('close-radio-btn');

  // Load and play radio station
  function tuneIn(streamUrl, stationName, genre) {
    radioAudio.src = streamUrl;
    stationNameEl.textContent = stationName;
    stationGenreEl.textContent = genre;
    radioPlayer.style.display = 'block';
    radioAudio.play().catch(function(error) {
      console.error('Error playing stream:', error);
      alert('Error: Unable to connect to radio stream. Please check the stream URL.');
    });
  }

  // Stop button
  stopBtn.addEventListener('click', function() {
    radioAudio.pause();
    radioAudio.currentTime = 0;
    radioPlayer.style.display = 'none';
    radioAudio.src = '';
  });

  // Volume control
  volumeControl.addEventListener('input', function() {
    radioAudio.volume = volumeControl.value / 100;
  });

  // Set initial volume
  radioAudio.volume = 0.7;

  // Close player
  closeRadioBtn.addEventListener('click', function() {
    radioAudio.pause();
    radioAudio.src = '';
    radioPlayer.style.display = 'none';
  });

  // Attach click handlers to all tune-in buttons
  document.querySelectorAll('.tune-in-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      const streamUrl = btn.dataset.streamUrl;
      const stationName = btn.dataset.stationName;
      const genre = btn.dataset.stationGenre;
      tuneIn(streamUrl, stationName, genre);
    });
  });
})();
</script>
