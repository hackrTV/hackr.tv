<div class="tui-window white-text" style="max-width: 1400px; background: #1a1a1a; border: 2px solid #666;">
  <fieldset style="border-color: #666;">
    <legend class="center" style="color: #a78bfa;">hackr.fm :: PULSE VAULT</legend>

    <div>
      <h2 style="text-align: center; margin-bottom: 15px; color: #a78bfa;">
        [:: MUSIC DISCOVERY :: ALL TRACKS ::]
      </h2>

      <div style="margin-bottom: 30px; padding: 15px; background: #0a0a0a; border: 1px solid #444;">
        <p style="color: #999; text-align: center;">
          <span id="visible-count"><%= @tracks.count %></span> / <%= @tracks.count %> tracks available for streaming | Browse by artist, discover by genre, experience the resistance
        </p>
      </div>

      <% if @tracks.any? %>
        <div style="margin-bottom: 20px;">
          <label for="track-search" style="color: #888; display: block; margin-bottom: 8px;">
            SEARCH TRACKS :: Filter by track, artist, album, or genre
          </label>
          <input type="text"
                 id="track-search"
                 placeholder="Type to filter tracks..."
                 value="<%= params[:filter] %>"
                 style="width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #555; color: #ccc; font-family: monospace; font-size: 1em;">
        </div>

        <div class="tui-fieldset" style="border-color: #555;">
          <legend style="color: #888;">TRACK LIBRARY</legend>
          <table class="tui-table" style="width: 100%; border-collapse: separate; border-spacing: 0 2px;">
            <thead>
              <tr>
                <th style="text-align: left; color: #888;">&nbsp;Track</th>
                <th style="text-align: left; color: #888;">&nbsp;Artist</th>
                <th style="text-align: left; color: #888;">&nbsp;Album</th>
                <th style="text-align: left; color: #888;">&nbsp;Genre</th>
                <th style="text-align: center; color: #888; width: 120px; min-width: 120px;">Stream</th>
              </tr>
            </thead>
            <tbody>
              <% @tracks.each do |track| %>
                <tr data-track-id="<%= track.id %>"
                    data-track-name="<%= track.title.downcase %>"
                    data-artist-name="<%= track.artist.name.downcase %>"
                    data-album-name="<%= track.album.name.downcase %>"
                    data-genre="<%= track.artist.genre&.downcase || '' %>"
                    class="track-row"
                    style="<%= track.audio_file.attached? ? '' : 'opacity: 0.4;' %>">
                  <td>
                    <% if track.audio_file.attached? %>
                      &nbsp;
                      <strong class="track-title-clickable"
                              data-track-url="<%= url_for(track.audio_file) %>"
                              data-track-title="<%= track.title %>"
                              data-track-artist="<%= track.artist.name %>"
                              data-track-id="<%= track.id %>"
                              data-cover-url="<%= track.album.cover_image.attached? ? url_for(track.album.cover_image) : '' %>"
                              style="color: #ccc; cursor: pointer;">
                        <span class="now-playing-indicator" style="display: none;">★ </span><%= track.title %>
                      </strong>
                      &nbsp;
                    <% else %>
                      &nbsp;
                      <strong style="color: #666;">
                        <%= track.title %>
                      </strong>
                      &nbsp;
                    <% end %>
                  </td>
                  <td style="color: <%= track.audio_file.attached? ? '#aaa' : '#555' %>;">&nbsp;<%= track.artist.name %>&nbsp;</td>
                  <td style="color: <%= track.audio_file.attached? ? '#999' : '#555' %>;">&nbsp;<%= track.album.name || '—' %>&nbsp;</td>
                  <td style="color: <%= track.audio_file.attached? ? '#999' : '#555' %>;">&nbsp;<%= track.artist.genre || '—' %>&nbsp;</td>
                  <td style="text-align: center; width: 135px; min-width: 135px;">
                    <% if track.audio_file.attached? %>
                      &nbsp;
                      <button class="tui-button play-track-btn"
                              data-track-url="<%= url_for(track.audio_file) %>"
                              data-track-title="<%= track.title %>"
                              data-track-artist="<%= track.artist.name %>"
                              data-track-id="<%= track.id %>"
                              data-cover-url="<%= track.album.cover_image.attached? ? url_for(track.album.cover_image) : '' %>"
                              style="padding: 2px 12px; font-size: 0.85em; background: #7c3aed; color: white;">
                        ► PLAY
                      </button>
                      &nbsp;
                    <% else %>
                      &nbsp;
                      <span style="color: #555;">—</span>
                      &nbsp;
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a;">
          <p style="color: #999; font-size: 1.2em;">No tracks available yet. The vault is empty.</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>
