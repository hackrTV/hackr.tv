<div class="tui-window white-text admin-panel" style="display: block; max-width: 1200px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/redirects :: MANAGE REDIRECTS</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Actions -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
        <%= link_to "← Dashboard", admin_root_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
        <%= link_to "➕ New Redirect", new_admin_redirect_path, class: "tui-button purple-168", style: "padding: 8px 20px; margin-left: auto;" %>
      </div>

      <!-- Redirects Table -->
      <% if @redirects.any? %>
        <div class="tui-window white-text" style="display: block; background: #0a0a0a; margin-top: 20px;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Domain</th>
                <th style="text-align: left;">Path</th>
                <th style="text-align: left;">Destination</th>
                <th style="text-align: center;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @redirects.each do |redirect| %>
                <tr class="admin-table-row">
                  <td style="font-family: monospace; color: #888;"><%= redirect.domain || "(global)" %></td>
                  <td style="font-family: monospace;"><%= redirect.path %></td>
                  <td style="font-family: monospace; color: #0ff; max-width: 300px; overflow: hidden; text-overflow: ellipsis;" title="<%= redirect.destination_url %>"><%= truncate(redirect.destination_url, length: 50) %></td>
                  <td style="text-align: center;">
                    <%= link_to "✎ Edit", edit_admin_redirect_path(redirect), class: "tui-button cyan-168", style: "padding: 2px 10px; margin: 0 5px; font-size: 0.9em;" %>
                    <%= button_to "✗ Delete", admin_redirect_path(redirect), method: :delete,
                        data: { confirm: "Delete redirect '#{redirect.domain || '(global)'}#{redirect.path}'?" },
                        class: "tui-button red-168",
                        style: "padding: 2px 10px; font-size: 0.9em; display: inline-block;" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
          <p style="color: #666; font-size: 1.2em;">No redirects configured. Create your first one!</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>
