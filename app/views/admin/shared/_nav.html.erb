<style>
  .admin-nav-dropdown {
    position: relative;
    display: inline-block;
  }
  .admin-nav-dropdown-trigger {
    cursor: pointer;
    text-decoration: none;
  }
  .admin-nav-dropdown-trigger:after {
    content: " ▾";
    font-size: 0.7em;
  }
  .admin-nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #1a1a1a;
    border: 1px solid #00ffff;
    min-width: 120px;
    z-index: 1000;
    padding: 10px 0 5px 0;
  }
  .admin-nav-dropdown::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 10px;
  }
  .admin-nav-dropdown:hover .admin-nav-dropdown-menu {
    display: block;
  }
  .admin-nav-dropdown-menu a {
    display: block;
    padding: 8px 15px;
    text-decoration: none;
    white-space: nowrap;
  }
  .admin-nav-dropdown-menu a:hover {
    background: #333;
  }
</style>

<div style="background: #0a0a0a; border-bottom: 2px solid #00ffff; padding: 15px 20px; margin-bottom: 20px;">
  <div style="max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <span class="cyan-255-text" style="font-weight: bold; font-size: 1.2em;">/root</span>
      <span style="color: #666; margin: 0 10px;">|</span>
      <% if current_hackr %>
        <span style="color: #888;">Logged in as:</span>
        <span class="purple-168-text"><%= current_hackr.hackr_alias %></span>
        <% if current_hackr.admin? %>
          <span class="red-255-text">[ADMIN]</span>
        <% end %>
      <% end %>
    </div>

    <nav style="display: flex; gap: 20px; align-items: center;">
      <%= link_to "Dashboard", admin_root_path, class: "cyan-168-text", style: "text-decoration: none;" %>
      <div class="admin-nav-dropdown">
        <span class="admin-nav-dropdown-trigger cyan-168-text">Music</span>
        <div class="admin-nav-dropdown-menu">
          <%= link_to "Artists", admin_artists_path, class: "cyan-168-text" %>
          <%= link_to "Releases", admin_releases_path, class: "cyan-168-text" %>
          <%= link_to "Tracks", admin_tracks_path, class: "cyan-168-text" %>
          <%= link_to "Radio", admin_radio_stations_path, class: "cyan-168-text" %>
        </div>
      </div>
      <%= link_to "Logs", admin_hackr_logs_path, class: "cyan-168-text", style: "text-decoration: none;" %>
      <%= link_to "Codex", admin_codex_entries_path, class: "cyan-168-text", style: "text-decoration: none;" %>
      <%= link_to "Streams", admin_hackr_streams_path, class: "green-255-text", style: "text-decoration: none;" %>
      <%= link_to "PulseWire", admin_pulse_wire_index_path, class: "purple-168-text", style: "text-decoration: none;" %>
      <%= link_to "Uplink", admin_uplink_index_path, class: "purple-168-text", style: "text-decoration: none;" %>
      <%= link_to "Overlays", admin_overlays_path, class: "yellow-168-text", style: "text-decoration: none;" %>
      <%= link_to "GRID", admin_grid_path, class: "green-168-text", style: "text-decoration: none;" %>
      <%= link_to "Redirects", admin_redirects_path, class: "cyan-168-text", style: "text-decoration: none;" %>
      <span style="color: #333;">|</span>
      <%= link_to "← Exit Admin", root_path, class: "red-168-text", style: "text-decoration: none;" %>
    </nav>
  </div>
</div>
