<% content_for(:title) { "/root/overlays/scenes/#{@scene.slug} :: Scene Details" } %>

<div class="tui-window white-text admin-panel" style="display: block; max-width: 1000px; margin: 30px auto;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/overlays/scenes/<%= @scene.slug %> :: SCENE DETAILS</legend>

    <div style="margin-bottom: 30px; display: flex; gap: 10px;">
      <%= link_to "< Back to Scenes", admin_overlay_scenes_path, class: "tui-button green-168" %>
      <%= link_to "Edit", edit_admin_overlay_scene_path(@scene), class: "tui-button cyan-168" %>
      <%= link_to "Preview", overlay_scene_path(slug: @scene.slug), target: "_blank", class: "tui-button purple-168" %>
    </div>

    <div style="background: #0a0a0a; border: 1px solid #444; padding: 20px; margin-bottom: 20px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div>
          <p style="color: #888; margin: 0;">Name</p>
          <p style="margin: 5px 0 15px; font-size: 1.2rem;"><strong><%= @scene.name %></strong></p>

          <p style="color: #888; margin: 0;">Slug</p>
          <p style="margin: 5px 0 15px;"><code><%= @scene.slug %></code></p>

          <p style="color: #888; margin: 0;">Scene Type</p>
          <p style="margin: 5px 0 15px;"><%= @scene.scene_type.titleize %></p>
        </div>
        <div>
          <p style="color: #888; margin: 0;">Dimensions</p>
          <p style="margin: 5px 0 15px;"><%= @scene.width %> x <%= @scene.height %> px</p>

          <p style="color: #888; margin: 0;">Status</p>
          <p style="margin: 5px 0 15px;"><%= @scene.active ? '<span class="green-255-text">Active</span>'.html_safe : '<span class="red-168-text">Inactive</span>'.html_safe %></p>

          <p style="color: #888; margin: 0;">Overlay URL</p>
          <p style="margin: 5px 0 15px;"><code class="cyan-168-text"><%= overlay_scene_url(slug: @scene.slug) %></code></p>
        </div>
      </div>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
      <h3 class="cyan-255-text" style="margin: 0;">[:: SCENE ELEMENTS (<%= @elements.count %>) ::]</h3>
      <%= link_to "+ Add Element", new_admin_overlay_scene_scene_element_path(@scene), class: "tui-button green-168" %>
    </div>
    <div style="background: #0a0a0a; border: 1px solid #444; padding: 20px;">
      <% if @elements.any? %>
        <table class="tui-table" style="width: 100%;">
          <thead>
            <tr>
              <th>Z</th>
              <th>Element</th>
              <th>Type</th>
              <th>Position</th>
              <th>Size</th>
              <th style="width: 150px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @elements.each do |se| %>
              <tr>
                <td><%= se.z_index || 0 %></td>
                <td>
                  <strong><%= se.overlay_element.name %></strong>
                  <% if se.overrides.present? && se.overrides.any? %>
                    <% se.overrides.each do |key, value| %>
                      <br><small class="purple-168-text"><%= key.humanize %>: <%= value %></small>
                    <% end %>
                  <% end %>
                </td>
                <td><code><%= se.overlay_element.element_type %></code></td>
                <td>(<%= se.x || 0 %>, <%= se.y || 0 %>)</td>
                <td><%= se.width || "auto" %> x <%= se.height || "auto" %></td>
                <td>
                  <%= link_to "Edit", edit_admin_overlay_scene_scene_element_path(@scene, se), class: "tui-button cyan-168", style: "padding: 2px 8px; font-size: 0.85rem;" %>
                  <%= link_to "Remove", admin_overlay_scene_scene_element_path(@scene, se), method: :delete, data: { confirm: "Remove this element?" }, class: "tui-button red-168", style: "padding: 2px 8px; font-size: 0.85rem;" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p style="color: #666; text-align: center; margin: 0;">No elements in this scene. <%= link_to "Add one", new_admin_overlay_scene_scene_element_path(@scene), class: "cyan-168-text" %>.</p>
      <% end %>
    </div>

  </fieldset>
</div>
