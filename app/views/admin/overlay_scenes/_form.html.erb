<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <div>
    <%= form.label :name, "NAME *", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :name, class: "tui-input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.label :slug, "SLUG (auto-generated if blank)", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :slug, class: "tui-input", style: "width: 100%;", placeholder: "auto-generated" %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <div>
    <%= form.label :scene_type, "SCENE TYPE *", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.select :scene_type, OverlayScene::SCENE_TYPES.map { |t| [t.titleize, t] }, {}, class: "tui-input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.label :width, "WIDTH (px)", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.number_field :width, class: "tui-input", style: "width: 100%;", value: form.object.width || 1920 %>
  </div>
  <div>
    <%= form.label :height, "HEIGHT (px)", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.number_field :height, class: "tui-input", style: "width: 100%;", value: form.object.height || 1080 %>
  </div>
  <div>
    <%= form.label :active, "STATUS", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.select :active, [["Active", true], ["Inactive", false]], {}, class: "tui-input", style: "width: 100%;" %>
  </div>
</div>

<div style="margin-bottom: 20px;">
  <%= form.label :position, "POSITION (for ordering)", style: "display: block; color: #888; margin-bottom: 5px;" %>
  <%= form.number_field :position, class: "tui-input", style: "width: 200px;", value: form.object.position || 0 %>
</div>
