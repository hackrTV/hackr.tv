<% content_for(:title) { "/root/overlays/scenes/#{@scene.slug}/edit :: Edit Scene" } %>

<div class="tui-window cyan-168 white-text" style="display: block; max-width: 900px; margin: 30px auto;">
  <fieldset class="cyan-168-border">
    <legend class="center">/root/overlays/scenes/<%= @scene.slug %>/edit :: EDIT SCENE</legend>

    <% if flash[:error] %>
      <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin-bottom: 20px;">
        <p class="red-255-text" style="margin: 0;">&#10007; ERROR</p>
        <p class="white-text" style="margin: 5px 0 0;"><%= flash[:error] %></p>
      </div>
    <% end %>

    <div style="margin-bottom: 30px; display: flex; gap: 10px;">
      <%= link_to "< Back to Scenes", admin_overlay_scenes_path, class: "tui-button green-168" %>
      <%= link_to "Preview", overlay_scene_path(slug: @scene.slug), target: "_blank", class: "tui-button purple-168" %>
    </div>

    <%= form_with model: [:admin, @scene], local: true do |form| %>
      <%= render "form", form: form %>

      <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
        <%= form.submit "Update Scene", class: "tui-button cyan-168" %>
        <%= link_to "Cancel", admin_overlay_scenes_path, class: "tui-button red-168", style: "margin-left: 10px;" %>
        <%= link_to "Delete", admin_overlay_scene_path(@scene), method: :delete, data: { confirm: "Are you sure you want to delete this scene?" }, class: "tui-button red-168", style: "margin-left: 10px;" %>
      </div>
    <% end %>

    <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
        <h3 class="cyan-255-text" style="margin: 0;">[:: SCENE ELEMENTS (<%= @scene_elements.count %>) ::]</h3>
        <%= link_to "+ Add Element", new_admin_overlay_scene_scene_element_path(@scene), class: "tui-button green-168" %>
      </div>
      <% if @scene_elements.any? %>
        <table class="tui-table" style="width: 100%;">
          <thead>
            <tr>
              <th>Element</th>
              <th>Type</th>
              <th>Position (X, Y)</th>
              <th>Size (W x H)</th>
              <th>Z-Index</th>
              <th style="width: 150px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @scene_elements.each do |se| %>
              <tr>
                <td><%= se.overlay_element.name %></td>
                <td><%= se.overlay_element.element_type %></td>
                <td><%= se.x || 0 %>, <%= se.y || 0 %></td>
                <td><%= se.width || "auto" %> x <%= se.height || "auto" %></td>
                <td><%= se.z_index || 0 %></td>
                <td>
                  <%= link_to "Edit", edit_admin_overlay_scene_scene_element_path(@scene, se), class: "tui-button cyan-168", style: "padding: 2px 8px; font-size: 0.85rem;" %>
                  <%= link_to "Remove", admin_overlay_scene_scene_element_path(@scene, se), method: :delete, data: { confirm: "Remove?" }, class: "tui-button red-168", style: "padding: 2px 8px; font-size: 0.85rem;" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p style="color: #666; text-align: center; margin: 0;">No elements in this scene yet.</p>
      <% end %>
    </div>

  </fieldset>
</div>
