<div class="tui-window cyan-168 white-text" style="max-width: 900px; margin: 30px auto;">
  <fieldset class="cyan-168-border">
    <legend class="center">/root/grid_zones/<%= @zone.id %> :: EDIT ZONE</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Zone Info -->
      <div class="tui-window white-text" style="background: #0a0a0a; margin-bottom: 20px; padding: 20px;">
        <h3 class="cyan-255-text" style="margin-top: 0;">ZONE INFO</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
          <div>
            <p style="color: #888; margin-bottom: 5px;">NAME</p>
            <p><%= @zone.name %></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">SLUG</p>
            <p style="font-family: monospace;">/<%= @zone.slug %></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">TYPE</p>
            <p><%= @zone.zone_type || "—" %></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">FACTION</p>
            <p><%= @zone.grid_faction&.name || "—" %></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">ROOMS</p>
            <p class="cyan-255-text"><%= @zone.grid_rooms.count %> rooms</p>
          </div>
        </div>
      </div>

      <!-- Edit Form -->
      <%= form_with model: [:admin, @zone], local: true do |f| %>
        <h3 class="cyan-255-text" style="margin: 20px 0 15px 0;">[:: AMBIENT PLAYLIST ::]</h3>

        <div style="margin-bottom: 20px;">
          <%= f.label :ambient_playlist_id, "AMBIENT PLAYLIST", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
          <%= f.select :ambient_playlist_id,
              options_from_collection_for_select(@zone_playlists, :id, :name, @zone.ambient_playlist_id),
              { include_blank: "None (rooms will have no ambient music by default)" },
              class: "tui-input", style: "width: 100%;" %>
          <small style="color: #888;">This playlist will play in all rooms in this zone unless a room has its own playlist assigned.</small>
        </div>

        <div class="center" style="margin: 30px 0;">
          <%= f.submit "Update Zone", class: "tui-button purple-168", style: "font-size: 1.1em; padding: 10px 30px;" %>
          <%= link_to "Cancel", admin_grid_zones_path, class: "tui-button green-168", style: "font-size: 1.1em; padding: 10px 30px; margin-left: 10px;" %>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>
