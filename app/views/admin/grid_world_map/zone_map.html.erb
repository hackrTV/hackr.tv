<div class="tui-window white-text admin-panel" style="display: block; max-width: 1600px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/grid/world-map/<%= @region.slug %>/<%= @zone.slug %> :: ZONE MAP</legend>

    <div style="padding: 20px;">
      <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;">
        <%= link_to "<- #{@region.name}", admin_grid_world_map_path(@region), class: "tui-button", style: "padding: 6px 14px;" %>
        <%= link_to "Edit Zone", edit_admin_grid_zone_path(@zone), class: "tui-button cyan-168", style: "padding: 6px 14px;" %>
      </div>

      <div style="margin-bottom: 20px;">
        <div class="tui-window white-text" style="display: block; background: #0a0a0a; padding: 15px;">
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">
            <div><span style="color: #888;">Zone:</span> <span class="cyan-255-text" style="font-weight: bold;"><%= @zone.name %></span></div>
            <div><span style="color: #888;">Type:</span> <span style="color: #888;"><%= @zone.zone_type || "—" %></span></div>
            <div><span style="color: #888;">Danger:</span> <span class="white-text"><%= @zone.danger_level %></span></div>
            <div><span style="color: #888;">Rooms:</span> <span class="white-text"><%= @map.placed_rooms.size + @map.unplaced_rooms.size %></span></div>
          </div>
        </div>
      </div>

      <% if @map.z_levels_present.size > 1 %>
        <div style="margin-bottom: 15px;">
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <% @map.z_levels_present.sort.each do |z| %>
              <% active = z == @z_level %>
              <% label = z == 0 ? "BASE (z=0)" : z > 0 ? "UP +#{z}" : "DOWN #{z}" %>
              <% if active %>
                <span class="tui-button green-168" style="padding: 4px 12px; font-size: 0.85em; cursor: default;"><%= label %></span>
              <% else %>
                <%= link_to label, zone_map_admin_grid_world_map_path(@region, zone_id: @zone.id, z: z), class: "tui-button", style: "padding: 4px 12px; font-size: 0.85em;" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: ZONE MAP (z=<%= @z_level %>) ::]</h3>
      <div style="border: 1px solid #333; overflow-x: auto;">
        <%= raw @map.svg %>
      </div>

      <% if @map.cross_exits.any? %>
        <div style="margin-top: 15px;">
          <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: EXITS TO OTHER ZONES ::]</h3>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: left;">From Room</th>
                  <th style="text-align: center;">Dir</th>
                  <th style="text-align: left;">To Zone</th>
                  <th style="text-align: left;">To Room</th>
                </tr>
              </thead>
              <tbody>
                <% @map.cross_exits.each do |cx| %>
                  <tr>
                    <td style="color: #d0d0d0;"><%= cx[:from_room]&.name || "—" %></td>
                    <td style="text-align: center; color: #fbbf24;"><%= cx[:direction] %></td>
                    <td style="color: #888;"><%= cx[:to_zone]&.name || "—" %></td>
                    <td style="color: #888;"><%= cx[:to_room]&.name || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <% if @map.unplaced_rooms.any? %>
        <div style="margin-top: 15px;">
          <h3 class="yellow-255-text" style="margin-bottom: 10px;">[:: UNREACHABLE ROOMS ::]</h3>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" style="width: 100%;">
              <tbody>
                <% @map.unplaced_rooms.each do |room| %>
                  <tr>
                    <td><%= room.name %></td>
                    <td style="color: #888;"><%= room.room_type || "—" %></td>
                    <td><%= link_to "Edit", edit_admin_grid_room_path(room), class: "tui-button cyan-168", style: "padding: 3px 10px; font-size: 0.85em;" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
        <%= link_to "<- #{@region.name}", admin_grid_world_map_path(@region), class: "tui-button green-168" %>
      </div>
    </div>
  </fieldset>
</div>
