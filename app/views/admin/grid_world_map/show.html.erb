<div class="tui-window white-text admin-panel" style="display: block; max-width: 1600px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/grid/world-map/<%= @region.slug %> :: <%= @region.name.upcase %></legend>

    <div style="padding: 20px;">
      <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;">
        <%= link_to "<- All Regions", admin_grid_world_map_index_path, class: "tui-button", style: "padding: 6px 14px;" %>
        <%= link_to "Edit Region", edit_admin_grid_region_path(@region), class: "tui-button cyan-168", style: "padding: 6px 14px;" %>
      </div>

      <%# Zone legend %>
      <div style="margin-bottom: 20px;">
        <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: ZONE LEGEND ::]</h3>
        <div class="tui-window white-text" style="display: block; background: #0a0a0a; padding: 15px;">
          <div style="display: flex; gap: 20px; flex-wrap: wrap;">
            <% @zones.each do |zone| %>
              <% color = @zone_colors[zone.id] || "#888" %>
              <span>
                <span style="color: <%= color %>; font-weight: bold;">■</span>
                <span style="color: <%= color %>;"><%= zone.name %></span>
                <span style="color: #555;">(<%= zone.grid_rooms.size %> rooms)</span>
                <% if zone.grid_rooms.size > 5 %>
                  <%= link_to "[solo]", zone_map_admin_grid_world_map_path(@region, zone_id: zone.id, z: 0), style: "color: #666; text-decoration: none; font-size: 0.85em;" %>
                <% end %>
              </span>
            <% end %>
          </div>
        </div>
      </div>

      <%# Z-axis navigation %>
      <% if @map.z_levels_present.size > 1 %>
        <div style="margin-bottom: 15px;">
          <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: Z-LEVEL ::]</h3>
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            <% @map.z_levels_present.sort.each do |z| %>
              <% active = z == @z_level %>
              <% label = z == 0 ? "BASE (z=0)" : z > 0 ? "UP +#{z}" : "DOWN #{z}" %>
              <% if active %>
                <span class="tui-button green-168" style="padding: 4px 12px; font-size: 0.85em; cursor: default;"><%= label %></span>
              <% else %>
                <%= link_to label, admin_grid_world_map_path(@region, z: z), class: "tui-button", style: "padding: 4px 12px; font-size: 0.85em;" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Warnings %>
      <% if @map.conflicts.any? %>
        <div style="background: #332200; border: 2px solid #fbbf24; padding: 15px; margin-bottom: 15px;">
          <p class="yellow-255-text" style="font-weight: bold; margin-bottom: 8px;">LAYOUT CONFLICTS</p>
          <ul style="color: #888; margin: 0 0 0 20px;">
            <% @map.conflicts.each do |c| %>
              <li><%= c %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @map.components > 1 %>
        <div style="background: #1a1a2e; border: 2px solid #60a5fa; padding: 10px 15px; margin-bottom: 15px;">
          <span class="cyan-255-text"><%= @map.components %> disconnected room groups. Groups separated vertically.</span>
        </div>
      <% end %>

      <%# Map %>
      <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: REGION MAP (z=<%= @z_level %>) ::]</h3>
      <div style="border: 1px solid #333; overflow-x: auto;">
        <%= raw @map.svg %>
      </div>

      <%# Legend %>
      <div style="margin-top: 10px; padding: 10px; border: 1px solid #222; background: #0a0a0a;">
        <span style="color: #666; font-size: 0.85em;">
          Click room to edit ·
          <span style="color: #34d399;">NH</span>=hackrs ·
          <span style="color: #f87171;">NM</span>=mobs ·
          <span style="color: #f87171;">red border</span>=locked ·
          hover for details
        </span>
      </div>

      <%# Cross-region exits %>
      <% if @map.cross_exits.any? %>
        <div style="margin-top: 20px;">
          <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: CROSS-REGION EXITS ::]</h3>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: left;">From Room</th>
                  <th style="text-align: center;">Dir</th>
                  <th style="text-align: left;">To Region</th>
                  <th style="text-align: left;">To Room</th>
                </tr>
              </thead>
              <tbody>
                <% @map.cross_exits.each do |cx| %>
                  <tr>
                    <td style="color: #d0d0d0;"><%= cx[:from_room]&.name || "—" %></td>
                    <td style="text-align: center; color: #fbbf24;"><%= cx[:direction] %></td>
                    <td>
                      <% if cx[:to_region] %>
                        <%= link_to cx[:to_region].name, admin_grid_world_map_path(cx[:to_region]), style: "color: #00ffff; text-decoration: none;" %>
                      <% else %>
                        <span style="color: #666;">unknown</span>
                      <% end %>
                    </td>
                    <td style="color: #888;"><%= cx[:to_room]&.name || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <%# Unplaced rooms %>
      <% if @map.unplaced_rooms.any? %>
        <div style="margin-top: 20px;">
          <h3 class="yellow-255-text" style="margin-bottom: 10px;">[:: UNREACHABLE ROOMS (<%= @map.unplaced_rooms.size %>) ::]</h3>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: left;">Room</th>
                  <th style="text-align: left;">Zone</th>
                  <th style="text-align: left;">Type</th>
                  <th style="text-align: center;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @map.unplaced_rooms.each do |room| %>
                  <tr>
                    <td><%= room.name %></td>
                    <td style="color: #888;"><%= room.grid_zone&.name || "—" %></td>
                    <td style="color: #888;"><%= room.room_type || "—" %></td>
                    <td style="text-align: center;">
                      <%= link_to "Edit", edit_admin_grid_room_path(room), class: "tui-button cyan-168", style: "padding: 3px 10px; font-size: 0.85em;" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <%# Zone table %>
      <div style="margin-top: 25px;">
        <h3 class="cyan-255-text" style="margin-bottom: 10px;">[:: ZONES (<%= @zones.count %>) ::]</h3>
        <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Zone</th>
                <th style="text-align: left;">Type</th>
                <th style="text-align: center;">Danger</th>
                <th style="text-align: center;">Rooms</th>
                <th style="text-align: left;">Faction</th>
                <th style="text-align: center;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @zones.each do |zone| %>
                <% color = @zone_colors[zone.id] || "#888" %>
                <tr>
                  <td>
                    <span style="color: <%= color %>;">■</span>
                    <%= link_to zone.name, edit_admin_grid_zone_path(zone), style: "color: #{color}; text-decoration: none;" %>
                  </td>
                  <td style="color: #888;"><%= zone.zone_type || "—" %></td>
                  <td style="text-align: center;">
                    <% if zone.danger_level > 0 %>
                      <span style="color: <%= zone.danger_level >= 7 ? '#f87171' : zone.danger_level >= 4 ? '#fbbf24' : '#34d399' %>;"><%= zone.danger_level %></span>
                    <% else %>
                      <span style="color: #666;">0</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;"><%= zone.grid_rooms.size %></td>
                  <td style="color: #888;"><%= zone.grid_faction&.name || "—" %></td>
                  <td style="text-align: center;">
                    <% if zone.grid_rooms.size > 1 %>
                      <%= link_to "Solo Map", zone_map_admin_grid_world_map_path(@region, zone_id: zone.id, z: 0), class: "tui-button green-168", style: "padding: 3px 10px; font-size: 0.85em;" %>
                    <% end %>
                    <%= link_to "Edit", edit_admin_grid_zone_path(zone), class: "tui-button cyan-168", style: "padding: 3px 10px; font-size: 0.85em;" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
        <%= link_to "<- All Regions", admin_grid_world_map_index_path, class: "tui-button green-168" %>
      </div>
    </div>
  </fieldset>
</div>
