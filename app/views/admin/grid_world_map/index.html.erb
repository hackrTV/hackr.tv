<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/grid/world-map :: WORLD MAP</legend>

    <div style="padding: 20px;">

      <div style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center; margin-bottom: 20px;">
        <%= link_to "Export World (.tar.gz)", admin_grid_world_export_path, class: "tui-button green-168", style: "padding: 6px 14px;" %>
        <span style="color: #555; font-size: 0.8em;">tar xzf world-export-*.tar.gz -C data/ &nbsp;→&nbsp; git diff data/world/ &nbsp;→&nbsp; commit</span>
      </div>

      <% if @connections.any? %>
        <div style="margin-bottom: 30px;">
          <h3 class="cyan-255-text" style="margin-bottom: 15px;">[:: INTER-REGION CONNECTIONS ::]</h3>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: left;">From Region</th>
                  <th style="text-align: left;">Room</th>
                  <th style="text-align: center;">Dir</th>
                  <th style="text-align: left;">To Region</th>
                  <th style="text-align: left;">Room</th>
                </tr>
              </thead>
              <tbody>
                <% @connections.each do |conn| %>
                  <tr>
                    <td><%= link_to conn[:from_region].name, admin_grid_world_map_path(conn[:from_region]), style: "color: #00ffff; text-decoration: none;" %></td>
                    <td style="color: #888;"><%= conn[:from_room].name %></td>
                    <td style="text-align: center; color: #fbbf24;"><%= conn[:direction] %></td>
                    <td><%= link_to conn[:to_region].name, admin_grid_world_map_path(conn[:to_region]), style: "color: #00ffff; text-decoration: none;" %></td>
                    <td style="color: #888;"><%= conn[:to_room].name %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      <% end %>

      <h3 class="cyan-255-text" style="margin-bottom: 15px;">[:: REGIONS (<%= @regions.count %>) ::]</h3>
      <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
        <table class="tui-table" style="width: 100%;">
          <thead>
            <tr>
              <th style="text-align: left;">Region</th>
              <th style="text-align: center;">Zones</th>
              <th style="text-align: center;">Rooms</th>
              <th style="text-align: center;">Danger Range</th>
              <th style="text-align: center;">Hospital</th>
              <th style="text-align: center;">PAC</th>
              <th style="text-align: center;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @regions.each do |region| %>
              <% zones = region.grid_zones %>
              <% room_count = zones.sum { |z| z.grid_rooms.size } %>
              <% dangers = zones.map(&:danger_level).reject(&:zero?) %>
              <% danger_range = dangers.any? ? "#{dangers.min}–#{dangers.max}" : "—" %>
              <tr>
                <td>
                  <%= link_to region.name, admin_grid_world_map_path(region), style: "color: #00ffff; text-decoration: none;" %>
                </td>
                <td style="text-align: center;"><%= zones.size %></td>
                <td style="text-align: center;"><%= room_count %></td>
                <td style="text-align: center;"><span style="color: <%= dangers.any? ? '#fbbf24' : '#666' %>;"><%= danger_range %></span></td>
                <td style="text-align: center;"><span style="color: <%= region.hospital_room_id ? '#34d399' : '#666' %>;"><%= region.hospital_room_id ? "YES" : "—" %></span></td>
                <td style="text-align: center;"><span style="color: <%= region.containment_room_id ? '#fbbf24' : '#666' %>;"><%= region.containment_room_id ? "YES" : "—" %></span></td>
                <td style="text-align: center;">
                  <%= link_to "Map →", admin_grid_world_map_path(region), class: "tui-button green-168", style: "padding: 3px 10px; font-size: 0.85em;" %>
                  <%= link_to "Edit", edit_admin_grid_region_path(region), class: "tui-button cyan-168", style: "padding: 3px 10px; font-size: 0.85em;" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
        <%= link_to "<- Admin Dashboard", admin_root_path, class: "tui-button green-168" %>
      </div>
    </div>
  </fieldset>
</div>
