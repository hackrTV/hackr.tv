<div class="tui-window cyan-168 white-text" style="max-width: 1600px; margin: 30px auto;">
  <fieldset class="cyan-168-border">
    <legend class="center">/root/streams :: MANAGE LIVESTREAMS</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Current Live Stream Status -->
      <% if @current_live %>
        <div style="background: #001a00; border: 2px solid #00ff00; padding: 20px; margin: 20px 0;">
          <p class="green-255-text" style="font-size: 1.5em; margin-bottom: 10px;">⚡ LIVE NOW</p>
          <p class="white-text"><strong><%= @current_live.artist.name %></strong></p>
          <% if @current_live.title.present? %>
            <p class="white-text"><%= @current_live.title %></p>
          <% end %>
          <p style="color: #888; margin-top: 10px;">
            Started: <%= @current_live.started_at.strftime("%Y-%m-%d %H:%M") %>
          </p>
        </div>
      <% else %>
        <div style="background: #1a1a1a; border: 2px solid #444; padding: 20px; margin: 20px 0;">
          <p style="color: #888; font-size: 1.2em;">⚫ No active livestream</p>
        </div>
      <% end %>

      <!-- Actions -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
        <%= link_to "← Dashboard", admin_root_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
        <div style="margin-left: auto; display: flex; gap: 10px;">
          <%= link_to "➕ New Stream", new_admin_hackr_stream_path, class: "tui-button purple-168", style: "padding: 8px 20px;" %>
        </div>
      </div>

      <!-- Streams Table -->
      <% if @hackr_streams.any? %>
        <div class="tui-window white-text" style="background: #0a0a0a; margin-top: 20px;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Artist</th>
                <th style="text-align: left;">Title</th>
                <th style="text-align: left;">URL</th>
                <th style="text-align: center;">Status</th>
                <th style="text-align: center;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @hackr_streams.each do |stream| %>
                <tr>
                  <td>
                    <strong class="cyan-255-text"><%= stream.artist.name %></strong>
                  </td>
                  <td>
                    <%= stream.title.presence || "—" %>
                    <% if stream.started_at.present? %>
                      <br>
                      <small style="color: #666;">
                        Last: <%= stream.started_at.strftime("%Y-%m-%d %H:%M") %>
                      </small>
                    <% end %>
                  </td>
                  <td>
                    <% if stream.url.present? %>
                      <small style="color: #888; font-family: monospace; word-break: break-all;">
                        <%= truncate(stream.url, length: 50) %>
                      </small>
                    <% else %>
                      <span style="color: #666;">—</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <% if stream.is_live %>
                      <span class="green-255-text" style="font-weight: bold;">⚡ LIVE</span>
                    <% else %>
                      <span style="color: #666;">⚫ Offline</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <div style="display: flex; gap: 5px; justify-content: center; flex-wrap: wrap;">
                      <% if stream.is_live %>
                        <%= button_to "⏸ End Stream", end_stream_admin_hackr_stream_path(stream),
                            class: "tui-button orange-168",
                            style: "padding: 2px 10px; font-size: 0.9em;",
                            data: { confirm: "End this livestream?" } %>
                      <% elsif stream.started_at.present? %>
                        <span class="tui-button grey-168"
                              style="padding: 2px 10px; font-size: 0.9em; opacity: 0.5; cursor: not-allowed;"
                              title="Stream already finished. Create a new stream to go live again.">
                          ✓ Finished
                        </span>
                      <% elsif stream.url.present? %>
                        <%= button_to "▶ Go Live", go_live_admin_hackr_stream_path(stream),
                            class: "tui-button green-168",
                            style: "padding: 2px 10px; font-size: 0.9em;",
                            data: { confirm: "Start livestream for #{stream.artist.name}?" } %>
                      <% else %>
                        <span class="tui-button grey-168"
                              style="padding: 2px 10px; font-size: 0.9em; opacity: 0.5; cursor: not-allowed;"
                              title="Set stream URL first">
                          ▶ Go Live
                        </span>
                      <% end %>
                      <%= link_to "✎ Edit", edit_admin_hackr_stream_path(stream),
                          class: "tui-button cyan-168",
                          style: "padding: 2px 10px; font-size: 0.9em;" %>
                      <%= button_to "✗ Delete", admin_hackr_stream_path(stream),
                          method: :delete,
                          data: { confirm: "Delete stream for #{stream.artist.name}?" },
                          class: "tui-button red-168",
                          style: "padding: 2px 10px; font-size: 0.9em;" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
          <p style="color: #666; font-size: 1.2em;">No streams configured yet. Create your first one!</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>
