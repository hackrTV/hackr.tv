<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center"><%= @radio_station.name %></legend>

    <div style="padding: 20px;">
      <div style="margin-bottom: 20px; display: flex; gap: 10px; align-items: center;">
        <%= link_to "← Back to Stations", admin_radio_stations_path, class: "tui-button green-168", style: "padding: 10px 20px;" %>
        <span style="color: #666; margin-left: 15px; font-size: 0.9em;">
          Edit via: <code style="color: #888;">data/system/radio_stations.yml</code> → <code style="color: #888;">rails data:radio_stations</code>
        </span>
      </div>

      <div class="tui-window purple-168 white-text" style="display: block; margin-bottom: 30px;">
        <fieldset class="purple-168-border">
          <legend>STATION DETAILS</legend>
          <div style="padding: 20px;">
            <table style="width: 100%; border-collapse: collapse;">
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold; width: 200px;">Slug</td>
                <td style="padding: 10px;"><code class="cyan-168-text"><%= @radio_station.slug %></code></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Description</td>
                <td style="padding: 10px;"><%= @radio_station.description %></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Genre</td>
                <td style="padding: 10px;"><%= @radio_station.genre %></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Color</td>
                <td style="padding: 10px;"><%= @radio_station.color %></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Stream URL</td>
                <td style="padding: 10px;"><%= @radio_station.stream_url.presence || "(none)" %></td>
              </tr>
              <tr>
                <td style="padding: 10px; font-weight: bold;">Position</td>
                <td style="padding: 10px;"><%= @radio_station.position %></td>
              </tr>
            </table>
          </div>
        </fieldset>
      </div>

      <div class="tui-window green-168 white-text">
        <fieldset class="green-168-border">
          <legend class="cyan-255-text">PLAYLISTS (<%= @radio_station.playlists.count %>)</legend>
          <div style="padding: 20px; background: #0a0a0a;">
            <% if @radio_station.playlists.any? %>
              <% @radio_station.radio_station_playlists.includes(:playlist).order(position: :asc).each do |rsp| %>
                <div style="background: #1a1a1a; border: 2px solid #00ff00; padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;">
                  <div>
                    <strong style="color: #00d9ff; font-size: 1.1em;"><%= rsp.playlist.name %></strong>
                    <small style="color: #888; margin-left: 10px;">(<%= rsp.playlist.track_count %> tracks)</small>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p style="color: #888;">No playlists assigned to this station.</p>
            <% end %>
            <p style="color: #666; font-size: 0.9em; margin-top: 15px;">
              Manage playlists via: <code style="color: #888;">data/playlists/key_playlists.yml</code>
            </p>
          </div>
        </fieldset>
      </div>
    </div>
  </fieldset>
</div>
