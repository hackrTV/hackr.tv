<div class="tui-window cyan-168 white-text" style="max-width: 1400px; margin: 30px auto;">
  <fieldset class="cyan-168-border">
    <legend class="center"><%= @radio_station.name %></legend>

    <div style="padding: 20px;">
      <div style="margin-bottom: 20px; display: flex; gap: 10px;">
        <%= link_to "✎ Edit Station", edit_admin_radio_station_path(@radio_station), class: "tui-button", style: "background: #ff9900; color: #000; padding: 10px 20px;" %>
        <%= link_to "← Back to Stations", admin_radio_stations_path, class: "tui-button green-168", style: "padding: 10px 20px;" %>
        <%= button_to "Delete Station", admin_radio_station_path(@radio_station),
                      method: :delete,
                      class: "tui-button",
                      style: "background: #cc0000; color: #fff; padding: 10px 20px;",
                      data: { confirm: "Are you sure? This will remove all playlist associations." } %>
      </div>

      <div class="tui-window purple-168 white-text" style="margin-bottom: 30px;">
        <fieldset class="purple-168-border">
          <legend>STATION DETAILS</legend>
          <div style="padding: 20px;">
            <table style="width: 100%; border-collapse: collapse;">
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold; width: 200px;">Slug</td>
                <td style="padding: 10px;"><code class="cyan-168-text"><%= @radio_station.slug %></code></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Description</td>
                <td style="padding: 10px;"><%= @radio_station.description %></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Genre</td>
                <td style="padding: 10px;"><%= @radio_station.genre %></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Color</td>
                <td style="padding: 10px;"><%= @radio_station.color %></td>
              </tr>
              <tr style="border-bottom: 1px solid #444;">
                <td style="padding: 10px; font-weight: bold;">Stream URL</td>
                <td style="padding: 10px;"><%= @radio_station.stream_url.presence || "(none)" %></td>
              </tr>
              <tr>
                <td style="padding: 10px; font-weight: bold;">Position</td>
                <td style="padding: 10px;"><%= @radio_station.position %></td>
              </tr>
            </table>
          </div>
        </fieldset>
      </div>

      <div class="tui-window green-168 white-text">
        <fieldset class="green-168-border">
          <legend class="cyan-255-text">PLAYLISTS (<%= @radio_station.playlists.count %>)</legend>
          <div style="padding: 20px; background: #0a0a0a;">
            <% if @radio_station.playlists.any? %>
              <p style="color: #00ff00; margin-bottom: 15px; font-weight: bold;">☰ Drag to reorder playlists</p>
              <div id="sortable-playlists" style="margin-bottom: 30px;">
                <% @radio_station.radio_station_playlists.includes(:playlist).order(position: :asc).each do |rsp| %>
                  <div style="background: #1a1a1a; border: 2px solid #00ff00; padding: 15px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; cursor: move;" data-playlist-id="<%= rsp.playlist_id %>">
                    <div>
                      <span class="handle" style="cursor: move; margin-right: 15px; color: #00ff00; font-weight: bold; font-size: 1.2em;">☰</span>
                      <strong style="color: #00d9ff; font-size: 1.1em;"><%= rsp.playlist.name %></strong>
                      <small style="color: #888; margin-left: 10px;">(<%= rsp.playlist.track_count %> tracks)</small>
                    </div>
                    <%= button_to "Remove", remove_playlist_admin_radio_station_path(@radio_station, radio_station_playlist_id: rsp.id),
                                  method: :delete,
                                  class: "tui-button",
                                  style: "background: #cc0000; color: #fff; padding: 8px 15px; font-weight: bold;",
                                  data: { confirm: "Remove this playlist from the station?" } %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p style="color: #888; margin-bottom: 30px;">No playlists assigned to this station yet.</p>
            <% end %>

            <hr style="border-color: #00ff00; border-width: 2px; margin: 30px 0;">

            <h4 class="cyan-255-text" style="margin-bottom: 15px; font-size: 1.3em;">➕ Add Playlist</h4>
            <% if @available_playlists.any? %>
              <%= form_with url: add_playlist_admin_radio_station_path(@radio_station), method: :post, style: "display: flex; gap: 10px; align-items: center;" do |f| %>
                <%= select_tag :playlist_id,
                               options_from_collection_for_select(@available_playlists, :id, :name),
                               style: "flex: 1; padding: 10px; background: #1a1a1a; border: 2px solid #00ff00; color: #fff; font-family: monospace; font-size: 1em;",
                               prompt: "Select a playlist..." %>
                <%= f.submit "Add Playlist", class: "tui-button", style: "background: #7c3aed; color: #fff; padding: 10px 20px; font-weight: bold;" %>
              <% end %>
            <% else %>
              <p style="color: #888;">All of your playlists are already assigned to this station.</p>
            <% end %>
          </div>
        </fieldset>
      </div>
    </div>
  </fieldset>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const sortableList = document.getElementById('sortable-playlists');
  if (sortableList) {
    const sortable = new Sortable(sortableList, {
      handle: '.handle',
      animation: 150,
      onEnd: function(evt) {
        const playlistIds = Array.from(sortableList.children).map(el => el.dataset.playlistId);

        fetch('<%= reorder_playlists_admin_radio_station_path(@radio_station) %>', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
          },
          body: JSON.stringify({ playlist_ids: playlistIds })
        })
        .then(response => {
          if (response.ok) {
            console.log('Playlists reordered successfully');
          } else {
            alert('Failed to save playlist order');
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Failed to save playlist order');
        });
      }
    });
  }
});
</script>
