<% if @radio_station.errors.any? %>
  <div class="tui-window red-168 white-text" style="display: block; margin-bottom: 20px;">
    <fieldset class="red-168-border">
      <legend>ERRORS</legend>
      <div style="padding: 15px;">
        <p><%= pluralize(@radio_station.errors.count, "error") %> prohibited this radio station from being saved:</p>
        <ul style="margin-left: 20px;">
          <% @radio_station.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </fieldset>
  </div>
<% end %>

<div style="margin-bottom: 20px;">
  <%= f.label :name, style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.text_field :name, required: true, style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace;" %>
  <small style="color: #666; font-size: 0.85em;">Display name of the radio station</small>
</div>

<div style="margin-bottom: 20px;">
  <%= f.label :slug, style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.text_field :slug, required: true, style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace;" %>
  <small style="color: #666; font-size: 0.85em;">URL-friendly identifier (auto-generated from name if left blank)</small>
</div>

<div style="margin-bottom: 20px;">
  <%= f.label :description, style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.text_area :description, rows: 3, style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace; resize: vertical;" %>
  <small style="color: #666; font-size: 0.85em;">Station description shown on the radio page</small>
</div>

<div style="margin-bottom: 20px;">
  <%= f.label :genre, style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.text_field :genre, style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace;" %>
  <small style="color: #666; font-size: 0.85em;">Music genre or category</small>
</div>

<div style="margin-bottom: 20px;">
  <%= f.label :color, style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.text_field :color, style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace;" %>
  <small style="color: #666; font-size: 0.85em;">TuiCSS color class (e.g., "green-168", "purple-168")</small>
</div>

<div style="margin-bottom: 20px;">
  <%= f.label :stream_url, "Stream URL", style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.text_field :stream_url, placeholder: "https://...", style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace;" %>
  <small style="color: #666; font-size: 0.85em;">Live stream URL (optional)</small>
</div>

<div style="margin-bottom: 20px;">
  <%= f.label :position, style: "display: block; margin-bottom: 5px; color: #00d9ff;" %>
  <%= f.number_field :position, min: 0, required: true, style: "width: 100%; padding: 10px; background: #1a1a1a; border: 1px solid #444; color: #fff; font-family: monospace;" %>
  <small style="color: #666; font-size: 0.85em;">Display order (lower numbers appear first)</small>
</div>
