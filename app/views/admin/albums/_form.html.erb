<%# Flash Messages %>
<% if flash[:error] %>
  <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
    <p class="red-255-text">⚠ ERROR</p>
    <p class="white-text"><%= flash[:error] %></p>
  </div>
<% end %>

<%# Album Form %>
<%= form_with model: [:admin, album], local: true do |f| %>
  <%# Basic Info Section %>
  <h3 class="cyan-255-text" style="margin: 20px 0 15px 0;">[:: BASIC INFO ::]</h3>

  <div style="margin-bottom: 20px;">
    <%= f.label :artist_id, "ARTIST", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
    <%= f.select :artist_id, options_from_collection_for_select(@artists, :id, :name, album.artist_id),
        { include_blank: "Select an artist..." },
        class: "tui-input", style: "width: 100%;" %>
    <% if album.errors[:artist_id].any? %>
      <small class="red-255-text"><%= album.errors[:artist_id].join(", ") %></small>
    <% end %>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
    <div>
      <%= f.label :name, "ALBUM NAME", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= f.text_field :name, class: "tui-input", placeholder: "Album Title", style: "width: 100%;" %>
      <% if album.errors[:name].any? %>
        <small class="red-255-text"><%= album.errors[:name].join(", ") %></small>
      <% end %>
    </div>

    <div>
      <%= f.label :slug, "SLUG", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= f.text_field :slug, class: "tui-input", placeholder: "album-title", style: "width: 100%; font-family: monospace;" %>
      <% if album.errors[:slug].any? %>
        <small class="red-255-text"><%= album.errors[:slug].join(", ") %></small>
      <% end %>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
    <div>
      <%= f.label :album_type, "ALBUM TYPE", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= f.select :album_type,
          options_for_select([
            ["Studio Album", "studio"],
            ["EP", "ep"],
            ["Single", "single"],
            ["Compilation", "compilation"],
            ["Live Album", "live"],
            ["Soundtrack", "soundtrack"],
            ["Demo", "demo"],
            ["Remix Album", "remix"]
          ], album.album_type),
          { include_blank: "Select type..." },
          class: "tui-input", style: "width: 100%;" %>
    </div>

    <div>
      <%= f.label :release_date, "RELEASE DATE", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
      <%= f.date_field :release_date, class: "tui-input", style: "width: 100%;" %>
    </div>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :description, "DESCRIPTION", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
    <%= f.text_area :description, class: "tui-input", placeholder: "Album description or notes...", style: "width: 100%; min-height: 100px; font-family: monospace; line-height: 1.6;" %>
  </div>

  <%# Cover Image Section %>
  <h3 class="cyan-255-text" style="margin: 30px 0 15px 0;">[:: COVER IMAGE ::]</h3>

  <% if album.cover_image.attached? %>
    <div style="padding: 15px; background: #0a0a0a; border: 1px solid #00ff00; margin-bottom: 15px;">
      <div style="display: flex; gap: 20px; align-items: flex-start;">
        <%= image_tag album.cover_image, style: "width: 150px; height: 150px; object-fit: cover; border: 2px solid #333;" %>
        <div>
          <p class="green-255-text" style="margin-bottom: 5px;">✓ Cover image attached</p>
          <p style="color: #aaa; font-size: 0.9em;"><%= album.cover_image.filename %></p>
          <p style="color: #666; font-size: 0.85em;">
            <%= number_to_human_size(album.cover_image.byte_size) %>
          </p>
          <label class="red-255-text" style="display: flex; align-items: center; gap: 10px; margin-top: 10px;">
            <%= check_box_tag "album[remove_cover_image]", "1", false, style: "width: auto;" %>
            <span>Remove current cover image</span>
          </label>
        </div>
      </div>
    </div>
  <% end %>

  <div style="margin-bottom: 20px;">
    <%= f.label :cover_image, "UPLOAD #{album.cover_image.attached? ? 'NEW ' : ''}COVER IMAGE", class: "white-text", style: "display: block; margin-bottom: 8px; font-weight: bold;" %>
    <%= f.file_field :cover_image, accept: "image/*", class: "tui-input", style: "width: 100%;" %>
    <small style="color: #888;">Supported: JPG, PNG, GIF, WebP | Recommended: 500x500px or larger square</small>
  </div>

  <%# Submit Buttons %>
  <div class="center" style="margin: 30px 0;">
    <%= f.submit (album.new_record? ? "Create Album" : "Update Album"), class: "tui-button purple-168", style: "font-size: 1.1em; padding: 10px 30px;" %>
    <%= link_to "Cancel", admin_albums_path, class: "tui-button green-168", style: "font-size: 1.1em; padding: 10px 30px; margin-left: 10px;" %>
  </div>
<% end %>
