<%# Flash Messages %>
<% if flash[:error] %>
  <div style="background: #330000; border: 1px solid #f87171; padding: 15px; margin: 20px 0;">
    <p style="color: #f87171; margin-bottom: 5px;">⚠ ERROR</p>
    <p style="color: #d0d0d0;"><%= flash[:error] %></p>
  </div>
<% end %>

<%# HackrLog Form %>
<%= form_with model: [:admin, hackr_log], local: true do |f| %>
  <div style="margin-bottom: 20px;">
    <%= f.label :title, "Title", style: "display: block; margin-bottom: 8px; font-weight: bold; color: #9ca3af;" %>
    <%= f.text_field :title, class: "tui-input", placeholder: "Log Entry Title", style: "width: 100%;" %>
    <% if hackr_log.errors[:title].any? %>
      <small style="color: #f87171;"><%= hackr_log.errors[:title].join(", ") %></small>
    <% end %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :slug, "Slug", style: "display: block; margin-bottom: 8px; font-weight: bold; color: #9ca3af;" %>
    <%= f.text_field :slug, class: "tui-input", placeholder: "log-entry-slug", style: "width: 100%; font-family: monospace;" %>
    <% if hackr_log.errors[:slug].any? %>
      <small style="color: #f87171;"><%= hackr_log.errors[:slug].join(", ") %></small>
    <% else %>
      <small style="color: #6b7280;">URL-friendly identifier (lowercase, no spaces)</small>
    <% end %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :body, "Body (Markdown)", style: "display: block; margin-bottom: 8px; font-weight: bold; color: #9ca3af;" %>
    <%= f.text_area :body, class: "tui-input", placeholder: "Write your log entry here...\n\nMarkdown is supported:\n\n# Heading\n## Subheading\n\n- Bullet point\n- Another point\n\n**Bold text**\n*Italic text*\n\n[Link](https://example.com)", style: "width: 100%; min-height: 400px; font-family: monospace; line-height: 1.6;" %>
    <% if hackr_log.errors[:body].any? %>
      <small style="color: #f87171;"><%= hackr_log.errors[:body].join(", ") %></small>
    <% else %>
      <small style="color: #6b7280;">Markdown supported - headings, lists, bold, italic, links, code blocks</small>
    <% end %>
  </div>

  <div style="margin-bottom: 30px;">
    <label style="display: flex; align-items: center; gap: 10px; color: #d0d0d0;">
      <%= f.check_box :published, style: "width: auto;" %>
      <span style="font-weight: bold;">Published</span>
      <span style="color: #6b7280;">(makes this log entry visible to the public)</span>
    </label>
    <% if hackr_log.published? && hackr_log.published_at %>
      <small style="color: #86efac; margin-left: 30px;">Published at: <%= hackr_log.published_at.strftime("%Y-%m-%d %H:%M") %></small>
    <% end %>
  </div>

  <div class="center" style="margin: 30px 0;">
    <%= f.submit (hackr_log.new_record? ? "Create Log Entry" : "Update Log Entry"), class: "tui-button purple-168", style: "font-size: 1.1em; padding: 10px 30px;" %>
    <%= link_to "Cancel", admin_hackr_logs_path, class: "tui-button green-168", style: "font-size: 1.1em; padding: 10px 30px; margin-left: 10px;" %>
  </div>
<% end %>

<% unless hackr_log.new_record? %>
  <div style="margin-top: 40px; padding: 20px; background: #0a0a0a; border: 1px solid #4b5563;">
    <h3 style="color: #a78bfa; margin-bottom: 15px;">Preview</h3>
    <div style="color: #b4b4b4; line-height: 1.8;">
      <%= markdown(hackr_log.body) %>
    </div>
    <small style="color: #6b7280; margin-top: 15px; display: block;">This shows how the log will appear on the public page.</small>
  </div>
<% end %>
