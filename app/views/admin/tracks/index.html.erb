<div class="tui-window cyan-168 white-text" style="max-width: 1400px; margin: 30px auto;">
  <fieldset class="cyan-168-border">
    <legend class="center">/root/tracks :: MANAGE TRACKS</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Actions -->
      <div style="margin-bottom: 20px;">
        <%= link_to "➕ New Track", new_admin_track_path, class: "tui-button purple-168", style: "padding: 8px 20px;" %>
        <%= button_to "📥 Import from YAML", import_admin_tracks_path, method: :post, class: "tui-button cyan-168", style: "padding: 8px 20px; margin-left: 10px; display: inline-block;", data: { confirm: "Import tracks from data/ directory?" } %>
        <%= link_to "← Dashboard", admin_root_path, class: "tui-button green-168", style: "padding: 8px 20px; margin-left: 10px;" %>
      </div>

      <!-- Tracks Table -->
      <% if @tracks.any? %>
        <div class="tui-window white-text" style="background: #0a0a0a; margin-top: 20px;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Track</th>
                <th style="text-align: left;">Artist</th>
                <th style="text-align: left;">Album</th>
                <th style="text-align: center;">Featured</th>
                <th style="text-align: center;">Audio</th>
                <th style="text-align: center;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @tracks.each do |track| %>
                <tr>
                  <td>
                    <strong><%= track.title %></strong>
                    <br>
                    <small style="color: #666; font-family: monospace;">/<%= track.slug %></small>
                  </td>
                  <td><%= track.artist.name %></td>
                  <td><%= track.album&.name || "—" %></td>
                  <td style="text-align: center;">
                    <% if track.featured %>
                      <span class="purple-255-text">★</span>
                    <% else %>
                      <span style="color: #333;">—</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <% if track.audio_file.attached? %>
                      <span class="green-255-text">✓</span>
                    <% else %>
                      <span style="color: #666;">✗</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <%= link_to "✎ Edit", edit_admin_track_path(track), class: "tui-button cyan-168", style: "padding: 2px 10px; margin: 0 5px; font-size: 0.9em;" %>
                    <%= button_to "✗ Delete", admin_track_path(track), method: :delete,
                        data: { confirm: "Delete track '#{track.title}'?" },
                        class: "tui-button red-168",
                        style: "padding: 2px 10px; font-size: 0.9em; display: inline-block;" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
          <p style="color: #666; font-size: 1.2em;">No tracks yet. Create your first one or import from YAML!</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>
