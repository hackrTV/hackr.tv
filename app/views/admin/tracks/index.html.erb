<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/tracks :: MANAGE TRACKS</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Navigation -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
        <%= link_to "← Dashboard", admin_root_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
        <span style="color: #666; margin-left: 15px; font-size: 0.9em;">
          Edit via: <code style="color: #888;">data/catalog/{artist_slug}.yml</code> → <code style="color: #888;">rails data:catalog</code>
        </span>
      </div>

      <!-- Search Filter -->
      <% if @tracks.any? %>
        <div style="margin-bottom: 20px;">
          <label for="track-search" style="color: #888; display: block; margin-bottom: 8px;">
            SEARCH TRACKS :: Filter by track title, artist, or album
          </label>
          <input
            type="text"
            id="track-search"
            placeholder="Type to filter tracks..."
            style="width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace; font-size: 1em;"
          />
          <div style="margin-top: 8px; color: #666; font-size: 0.9em;">
            <span id="track-count"><%= @tracks.count %></span> / <%= @tracks.count %> tracks visible
          </div>
        </div>
      <% end %>

      <!-- Tracks Table -->
      <% if @tracks.any? %>
        <div class="tui-window white-text" style="display: block; background: #0a0a0a; margin-top: 20px;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Track</th>
                <th style="text-align: left;">Artist</th>
                <th style="text-align: left;">Album</th>
                <th style="text-align: center;">Featured</th>
                <th style="text-align: center;">Audio</th>
                <th style="text-align: center;">Pulse Vault</th>
              </tr>
            </thead>
            <tbody>
              <% @tracks.each do |track| %>
                <tr class="track-row" class="admin-table-row"
                    data-track-title="<%= track.title.downcase %>"
                    data-artist-name="<%= track.artist.name.downcase %>"
                    data-album-name="<%= track.album&.name&.downcase || '' %>">
                  <td>
                    <strong><%= track.title %></strong>
                    <br>
                    <small style="color: #666; font-family: monospace;">/<%= track.slug %></small>
                  </td>
                  <td><%= track.artist.name %></td>
                  <td><%= track.album&.name || "—" %></td>
                  <td style="text-align: center;">
                    <% if track.featured %>
                      <span class="purple-255-text">★</span>
                    <% else %>
                      <span style="color: #333;">—</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <% if track.audio_file.attached? %>
                      <span class="green-255-text">✓</span>
                    <% else %>
                      <span style="color: #666;">✗</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <% if track.show_in_pulse_vault %>
                      <span class="green-255-text">✓</span>
                    <% else %>
                      <span style="color: #f87171;">✗</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
          <p style="color: #666; font-size: 1.2em;">No tracks yet. Create your first one or import from YAML!</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>

<% if @tracks.any? %>
  <script nonce="<%= content_security_policy_nonce %>">
    document.addEventListener('DOMContentLoaded', function() {
      const searchInput = document.getElementById('track-search');
      const trackRows = document.querySelectorAll('.track-row');
      const trackCountEl = document.getElementById('track-count');
      const totalTracks = trackRows.length;

      function filterTracks() {
        const searchTerm = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        trackRows.forEach(row => {
          const trackTitle = row.dataset.trackTitle || '';
          const artistName = row.dataset.artistName || '';
          const albumName = row.dataset.albumName || '';

          const matches = trackTitle.includes(searchTerm) ||
                         artistName.includes(searchTerm) ||
                         albumName.includes(searchTerm);

          if (matches) {
            row.style.display = '';
            visibleCount++;
          } else {
            row.style.display = 'none';
          }
        });

        trackCountEl.textContent = visibleCount;
      }

      searchInput.addEventListener('input', filterTracks);

      // Focus search on Tab key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Tab' && !e.shiftKey && document.activeElement !== searchInput) {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });
    });
  </script>
<% end %>
