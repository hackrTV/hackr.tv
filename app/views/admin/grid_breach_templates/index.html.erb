<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/grid/breach_templates :: BREACH TEMPLATES</legend>

    <div style="padding: 20px;">
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <div style="display: flex; gap: 15px; align-items: center; margin-bottom: 20px;">
        <%= link_to "+ New Template", new_admin_grid_breach_template_path, class: "tui-button green-168" %>
      </div>

      <div class="tui-window white-text" style="display: block; background: #0a0a0a; overflow-x: auto;">
        <table class="tui-table" style="width: 100%; min-width: 900px;">
          <thead>
            <tr>
              <th style="text-align: left;">Name</th>
              <th style="text-align: left;">Slug</th>
              <th style="text-align: center;">Tier</th>
              <th style="text-align: center;">CL</th>
              <th style="text-align: center;">PNR</th>
              <th style="text-align: center;">XP</th>
              <th style="text-align: center;">CRED</th>
              <th style="text-align: center;">Active</th>
              <th style="text-align: center;">Published</th>
              <th style="text-align: right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @templates.each do |t| %>
              <tr>
                <td><%= t.name %></td>
                <td style="color: #6b7280;"><%= t.slug %></td>
                <td style="text-align: center;"><%= t.tier_label %></td>
                <td style="text-align: center;"><%= t.min_clearance %></td>
                <td style="text-align: center;"><%= t.pnr_threshold %>%</td>
                <td style="text-align: center;"><%= t.xp_reward %></td>
                <td style="text-align: center;"><%= t.cred_reward %></td>
                <td style="text-align: center;"><%= @active_counts[t.id] || 0 %></td>
                <td style="text-align: center;">
                  <% if t.published? %>
                    <span class="green-255-text">&#10003;</span>
                  <% else %>
                    <span style="color: #6b7280;">&mdash;</span>
                  <% end %>
                </td>
                <td style="text-align: right; white-space: nowrap;">
                  <%= link_to "Edit", edit_admin_grid_breach_template_path(t), class: "tui-button", style: "padding: 2px 8px; font-size: 0.8em;" %>
                  <%= link_to "History", history_admin_grid_breach_template_path(t), class: "tui-button", style: "padding: 2px 8px; font-size: 0.8em;" %>
                  <%= link_to "Delete", admin_grid_breach_template_path(t), data: { turbo_method: :delete, turbo_confirm: "Delete template '#{t.name}'?" }, class: "tui-button red-168", style: "padding: 2px 8px; font-size: 0.8em;" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </fieldset>
</div>
