<% content_for(:title) { "/root/overlays/scenes/#{@scene.slug}/elements/new :: Add Element" } %>

<div class="tui-window white-text admin-panel" style="display: block; max-width: 700px; margin: 30px auto;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/overlays/scenes/<%= @scene.slug %>/elements/new :: ADD ELEMENT</legend>

    <% if flash[:error] %>
      <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin-bottom: 20px;">
        <p class="red-255-text" style="margin: 0;">&#10007; ERROR</p>
        <p class="white-text" style="margin: 5px 0 0;"><%= flash[:error] %></p>
      </div>
    <% end %>

    <div style="margin-bottom: 30px;">
      <%= link_to "< Back to Scene", admin_overlay_scene_path(@scene), class: "tui-button green-168" %>
    </div>

    <% if @available_elements.any? %>
      <%= form_with model: @scene_element, url: admin_overlay_scene_scene_elements_path(@scene), local: true do |form| %>
        <div style="margin-bottom: 20px;">
          <%= form.label :overlay_element_id, "SELECT ELEMENT *", style: "display: block; color: #888; margin-bottom: 5px;" %>
          <select name="overlay_scene_element[overlay_element_id]" id="overlay_scene_element_overlay_element_id" class="tui-input" style="width: 100%;">
            <option value="">-- Select an element --</option>
            <% @available_elements.group_by(&:element_type).each do |type, elements| %>
              <optgroup label="<%= type.titleize %>">
                <% elements.each do |element| %>
                  <option value="<%= element.id %>" data-element-type="<%= element.element_type %>"><%= element.name %></option>
                <% end %>
              </optgroup>
            <% end %>
          </select>
        </div>

        <div id="content-options-section" style="background: #111; border: 1px solid #333; padding: 15px; margin-bottom: 20px; display: none;">
          <h4 class="cyan-255-text" style="margin: 0 0 10px;">[:: CONTENT OPTIONS ::]</h4>
          <p style="color: #666; font-size: 0.85rem; margin: 0 0 15px;">
            <span style="color: #888;">Optional:</span> Override the element's default content for this scene.
          </p>

          <%# Lower Third content %>
          <div id="option-lower-third" class="content-option" style="display: none; margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px; font-size: 0.9rem;">
              LOWER THIRD CONTENT
            </label>
            <select name="lower_third_slug" class="tui-input" style="width: 100%;">
              <option value="">-- Use element default --</option>
              <% @lower_thirds.each do |lt| %>
                <option value="<%= lt.slug %>"><%= lt.name %></option>
              <% end %>
            </select>
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Select which lower third to display.</p>
          </div>

          <%# Ticker content %>
          <div id="option-ticker" class="content-option" style="display: none; margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px; font-size: 0.9rem;">
              TICKER CONTENT
            </label>
            <select name="ticker_slug" class="tui-input" style="width: 100%;">
              <option value="">-- Use element default --</option>
              <% @tickers.each do |t| %>
                <option value="<%= t.slug %>"><%= t.name %></option>
              <% end %>
            </select>
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Select which ticker messages to display.</p>
          </div>

          <%# Codex Entry content %>
          <div id="option-codex" class="content-option" style="display: none; margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px; font-size: 0.9rem;">
              CODEX ENTRY
            </label>
            <select name="codex_entry_slug" class="tui-input" style="width: 100%;">
              <option value="">-- Use element default --</option>
              <% @codex_entries.each do |ce| %>
                <option value="<%= ce.slug %>"><%= ce.name %> (<%= ce.entry_type %>)</option>
              <% end %>
            </select>
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Select which Codex entry to display.</p>
          </div>

          <%# Max Items setting %>
          <div id="option-max-items" class="content-option" style="display: none; margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px; font-size: 0.9rem;">
              MAX ITEMS
            </label>
            <input type="number" name="max_items" class="tui-input" style="width: 150px;" min="1" max="50" placeholder="5">
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Maximum number of items to show (default: 5).</p>
          </div>

          <%# No options message %>
          <div id="option-none" class="content-option" style="display: none;">
            <p style="color: #666; margin: 0; font-style: italic;">This element type has no configurable content options.</p>
          </div>
        </div>

        <h4 class="cyan-255-text" style="margin: 20px 0 15px;">[:: POSITION & SIZE ::]</h4>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
          <div>
            <%= form.label :x, "X POSITION (px)", style: "display: block; color: #888; margin-bottom: 5px;" %>
            <%= form.number_field :x, class: "tui-input", style: "width: 100%;", value: 0 %>
            <p style="color: #555; font-size: 0.8rem; margin: 3px 0 0;">Negative values = off-screen left</p>
          </div>
          <div>
            <%= form.label :y, "Y POSITION (px)", style: "display: block; color: #888; margin-bottom: 5px;" %>
            <%= form.number_field :y, class: "tui-input", style: "width: 100%;", value: 0 %>
            <p style="color: #555; font-size: 0.8rem; margin: 3px 0 0;">Negative values = off-screen top</p>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
          <div>
            <%= form.label :width, "WIDTH (px, blank=auto)", style: "display: block; color: #888; margin-bottom: 5px;" %>
            <%= form.number_field :width, class: "tui-input", style: "width: 100%;", min: 1, placeholder: "auto" %>
          </div>
          <div>
            <%= form.label :height, "HEIGHT (px, blank=auto)", style: "display: block; color: #888; margin-bottom: 5px;" %>
            <%= form.number_field :height, class: "tui-input", style: "width: 100%;", min: 1, placeholder: "auto" %>
          </div>
        </div>

        <div style="margin-bottom: 20px;">
          <%= form.label :z_index, "Z-INDEX (layer order)", style: "display: block; color: #888; margin-bottom: 5px;" %>
          <%= form.number_field :z_index, class: "tui-input", style: "width: 200px;", value: 0 %>
          <p style="color: #666; font-size: 0.9rem; margin: 5px 0 0;">Higher values appear on top of lower values.</p>
        </div>

        <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
          <%= form.submit "Add Element", class: "tui-button cyan-168" %>
          <%= link_to "Cancel", admin_overlay_scene_path(@scene), class: "tui-button red-168", style: "margin-left: 10px;" %>
        </div>
      <% end %>
    <% else %>
      <div style="background: #1a1a00; border: 2px solid #666600; padding: 20px; text-align: center;">
        <p class="yellow-255-text" style="margin: 0 0 10px;">No available elements to add.</p>
        <p style="color: #888; margin: 0;">All active elements are already in this scene, or no elements exist yet.</p>
        <div style="margin-top: 15px;">
          <%= link_to "Create New Element", new_admin_overlay_element_path, class: "tui-button green-168" %>
        </div>
      </div>
    <% end %>

  </fieldset>
</div>

<script nonce="<%= content_security_policy_nonce %>">
document.addEventListener('DOMContentLoaded', function() {
  const elementSelect = document.getElementById('overlay_scene_element_overlay_element_id');
  const contentSection = document.getElementById('content-options-section');
  const allOptions = document.querySelectorAll('.content-option');

  // Map element types to their content options
  const typeToOptions = {
    'lower_third': ['option-lower-third'],
    'ticker_top': ['option-ticker'],
    'ticker_bottom': ['option-ticker'],
    'codex_entry': ['option-codex'],
    'pulsewire_feed': ['option-max-items'],
    'grid_activity': ['option-max-items'],
    'now_playing': ['option-none'],
    'alert': ['option-none']
  };

  function updateContentOptions() {
    const selectedOption = elementSelect.options[elementSelect.selectedIndex];
    const elementType = selectedOption ? selectedOption.dataset.elementType : null;

    // Hide all options first
    allOptions.forEach(opt => opt.style.display = 'none');

    if (!elementType) {
      // No element selected - hide the whole section
      contentSection.style.display = 'none';
      return;
    }

    // Show the section
    contentSection.style.display = 'block';

    // Show relevant options for this element type
    const optionsToShow = typeToOptions[elementType] || ['option-none'];
    optionsToShow.forEach(optionId => {
      const el = document.getElementById(optionId);
      if (el) el.style.display = 'block';
    });
  }

  elementSelect.addEventListener('change', updateContentOptions);

  // Initial state
  updateContentOptions();
});
</script>
