<% content_for(:title) { "/root/overlays/scenes/#{@scene.slug}/elements/#{@scene_element.id}/edit :: Edit Element" } %>

<div class="tui-window white-text admin-panel" style="display: block; max-width: 700px; margin: 30px auto;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/overlays/scenes/<%= @scene.slug %>/elements :: EDIT ELEMENT</legend>

    <% if flash[:error] %>
      <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin-bottom: 20px;">
        <p class="red-255-text" style="margin: 0;">&#10007; ERROR</p>
        <p class="white-text" style="margin: 5px 0 0;"><%= flash[:error] %></p>
      </div>
    <% end %>

    <div style="margin-bottom: 30px;">
      <%= link_to "< Back to Scene", admin_overlay_scene_path(@scene), class: "tui-button green-168" %>
    </div>

    <div style="background: #0a0a0a; border: 1px solid #444; padding: 15px; margin-bottom: 20px;">
      <p style="color: #888; margin: 0 0 5px;">Element</p>
      <p style="margin: 0; font-size: 1.1rem;"><strong><%= @scene_element.overlay_element.name %></strong></p>
      <p style="margin: 5px 0 0;"><code class="cyan-168-text"><%= @scene_element.overlay_element.element_type %></code></p>
    </div>

    <%= form_with model: @scene_element, url: admin_overlay_scene_scene_element_path(@scene, @scene_element), method: :patch, local: true do |form| %>
      <% element = @scene_element.overlay_element %>
      <% element_type = element.element_type %>
      <% element_settings = element.settings || {} %>
      <% overrides = @scene_element.overrides || {} %>

      <div style="background: #111; border: 1px solid #333; padding: 15px; margin-bottom: 20px;">
        <h4 class="cyan-255-text" style="margin: 0 0 10px;">[:: CONTENT OPTIONS ::]</h4>
        <p style="color: #666; font-size: 0.85rem; margin: 0 0 15px;">
          <span style="color: #888;">Optional:</span> Override the element's default content for this scene.
        </p>

        <% if element_type == "lower_third" %>
          <div style="margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px;">LOWER THIRD CONTENT</label>
            <select name="lower_third_slug" class="tui-input" style="width: 100%;">
              <option value="">-- Use element default<%= " (#{element_settings['lower_third_slug']})" if element_settings['lower_third_slug'].present? %> --</option>
              <% @lower_thirds.each do |lt| %>
                <option value="<%= lt.slug %>" <%= "selected" if overrides["lower_third_slug"] == lt.slug %>><%= lt.name %></option>
              <% end %>
            </select>
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Select which lower third to display.</p>
          </div>

        <% elsif element_type.in?(["ticker_top", "ticker_bottom"]) %>
          <div style="margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px;">TICKER CONTENT</label>
            <select name="ticker_slug" class="tui-input" style="width: 100%;">
              <option value="">-- Use element default<%= " (#{element_settings['ticker_slug']})" if element_settings['ticker_slug'].present? %> --</option>
              <% @tickers.each do |t| %>
                <option value="<%= t.slug %>" <%= "selected" if overrides["ticker_slug"] == t.slug %>><%= t.name %></option>
              <% end %>
            </select>
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Select which ticker messages to display.</p>
          </div>

        <% elsif element_type == "codex_entry" %>
          <div style="margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px;">CODEX ENTRY</label>
            <select name="codex_entry_slug" class="tui-input" style="width: 100%;">
              <option value="">-- Use element default<%= " (#{element_settings['codex_entry_slug']})" if element_settings['codex_entry_slug'].present? %> --</option>
              <% @codex_entries.each do |ce| %>
                <option value="<%= ce.slug %>" <%= "selected" if overrides["codex_entry_slug"] == ce.slug %>><%= ce.name %> (<%= ce.entry_type %>)</option>
              <% end %>
            </select>
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Select which Codex entry to display.</p>
          </div>

        <% elsif element_type.in?(["pulsewire_feed", "grid_activity"]) %>
          <div style="margin-bottom: 15px;">
            <label style="display: block; color: #888; margin-bottom: 5px;">MAX ITEMS</label>
            <input type="number" name="max_items" class="tui-input" style="width: 150px;" min="1" max="50" value="<%= overrides["max_items"] %>" placeholder="<%= element_settings["max_items"] || 5 %>">
            <p style="color: #555; font-size: 0.8rem; margin: 5px 0 0;">Maximum number of items to show (element default: <%= element_settings["max_items"] || 5 %>).</p>
          </div>

        <% else %>
          <p style="color: #666; margin: 0; font-style: italic;">This element type has no configurable content options.</p>
        <% end %>
      </div>

      <h4 class="cyan-255-text" style="margin: 20px 0 15px;">[:: POSITION & SIZE ::]</h4>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <%= form.label :x, "X POSITION (px)", style: "display: block; color: #888; margin-bottom: 5px;" %>
          <%= form.number_field :x, class: "tui-input", style: "width: 100%;" %>
          <p style="color: #555; font-size: 0.8rem; margin: 3px 0 0;">Negative = off-screen left</p>
        </div>
        <div>
          <%= form.label :y, "Y POSITION (px)", style: "display: block; color: #888; margin-bottom: 5px;" %>
          <%= form.number_field :y, class: "tui-input", style: "width: 100%;" %>
          <p style="color: #555; font-size: 0.8rem; margin: 3px 0 0;">Negative = off-screen top</p>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div>
          <%= form.label :width, "WIDTH (px, blank=auto)", style: "display: block; color: #888; margin-bottom: 5px;" %>
          <%= form.number_field :width, class: "tui-input", style: "width: 100%;", min: 1, placeholder: "auto" %>
        </div>
        <div>
          <%= form.label :height, "HEIGHT (px, blank=auto)", style: "display: block; color: #888; margin-bottom: 5px;" %>
          <%= form.number_field :height, class: "tui-input", style: "width: 100%;", min: 1, placeholder: "auto" %>
        </div>
      </div>

      <div style="margin-bottom: 20px;">
        <%= form.label :z_index, "Z-INDEX (layer order)", style: "display: block; color: #888; margin-bottom: 5px;" %>
        <%= form.number_field :z_index, class: "tui-input", style: "width: 200px;" %>
        <p style="color: #666; font-size: 0.9rem; margin: 5px 0 0;">Higher values appear on top of lower values.</p>
      </div>

      <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
        <%= form.submit "Update Element", class: "tui-button cyan-168" %>
        <%= link_to "Cancel", admin_overlay_scene_path(@scene), class: "tui-button red-168", style: "margin-left: 10px;" %>
      </div>
    <% end %>

  </fieldset>
</div>

<div style="max-width: 700px; margin: 20px auto;">
  <%= button_to "Remove from Scene", admin_overlay_scene_scene_element_path(@scene, @scene_element),
      method: :delete,
      data: { confirm: "Remove this element from the scene?" },
      class: "tui-button red-168" %>
</div>
