<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/zone_playlists/<%= @zone_playlist.slug %> :: <%= @zone_playlist.name.upcase %></legend>

    <div style="padding: 20px;">
      <!-- Navigation -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px; align-items: center;">
        <%= link_to "← Back to Playlists", admin_zone_playlists_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
        <span style="color: #666; margin-left: 15px; font-size: 0.9em;">
          Edit via: <code style="color: #888;">data/system/zone_playlists.yml</code> → <code style="color: #888;">rails data:zone_playlists</code>
        </span>
      </div>

      <!-- Playlist Details -->
      <div class="tui-window white-text" style="display: block; background: #0a0a0a; margin-bottom: 20px; padding: 20px;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
          <div>
            <p style="color: #888; margin-bottom: 5px;">SLUG</p>
            <p><code class="cyan-168-text"><%= @zone_playlist.slug %></code></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">DESCRIPTION</p>
            <p><%= @zone_playlist.description || "—" %></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">CROSSFADE DURATION</p>
            <p><%= @zone_playlist.crossfade_duration_ms %> ms</p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">DEFAULT VOLUME</p>
            <p><%= (@zone_playlist.default_volume * 100).round %>%</p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">TRACK COUNT</p>
            <p class="cyan-255-text"><%= @tracks.count %> tracks</p>
          </div>
        </div>
      </div>

      <!-- Current Tracks -->
      <div style="margin-bottom: 30px;">
        <h3 style="color: #ccc; margin-bottom: 15px;">TRACKS</h3>

        <% if @tracks.any? %>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: center; width: 80px;">Position</th>
                  <th style="text-align: left;">Track</th>
                  <th style="text-align: left;">Artist</th>
                  <th style="text-align: left;">Album</th>
                </tr>
              </thead>
              <tbody>
                <% @tracks.each do |track| %>
                  <% zone_playlist_track = @zone_playlist.zone_playlist_tracks.find_by(track: track) %>
                  <tr>
                    <td style="text-align: center;">
                      <span class="cyan-255-text">#<%= zone_playlist_track.position %></span>
                    </td>
                    <td><strong><%= track.title %></strong></td>
                    <td><%= track.artist.name %></td>
                    <td><%= track.album&.name || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
            <p style="color: #666; font-size: 1.2em;">No tracks in this playlist.</p>
          </div>
        <% end %>
      </div>
    </div>
  </fieldset>
</div>
