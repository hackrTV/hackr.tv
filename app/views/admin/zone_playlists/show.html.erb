<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/zone_playlists/<%= @zone_playlist.id %> :: <%= @zone_playlist.name.upcase %></legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Actions -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px;">
        <%= link_to "← Back to Playlists", admin_zone_playlists_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
        <%= link_to "✎ Edit Details", edit_admin_zone_playlist_path(@zone_playlist), class: "tui-button cyan-168", style: "padding: 8px 20px;" %>
      </div>

      <!-- Playlist Details -->
      <div class="tui-window white-text" style="display: block; background: #0a0a0a; margin-bottom: 20px; padding: 20px;">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
          <div>
            <p style="color: #888; margin-bottom: 5px;">DESCRIPTION</p>
            <p><%= @zone_playlist.description || "—" %></p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">CROSSFADE DURATION</p>
            <p><%= @zone_playlist.crossfade_duration_ms %> ms</p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">DEFAULT VOLUME</p>
            <p><%= (@zone_playlist.default_volume * 100).round %>%</p>
          </div>
          <div>
            <p style="color: #888; margin-bottom: 5px;">TRACK COUNT</p>
            <p class="cyan-255-text"><%= @tracks.count %> tracks</p>
          </div>
        </div>
      </div>

      <!-- Current Tracks -->
      <div style="margin-bottom: 30px;">
        <h3 style="color: #ccc; margin-bottom: 15px;">CURRENT TRACKS</h3>

        <% if @tracks.any? %>
          <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
            <table class="tui-table" id="playlist-tracks-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: center; width: 50px;">Drag</th>
                  <th style="text-align: center; width: 80px;">Position</th>
                  <th style="text-align: left;">Track</th>
                  <th style="text-align: left;">Artist</th>
                  <th style="text-align: left;">Album</th>
                  <th style="text-align: center; width: 120px;">Actions</th>
                </tr>
              </thead>
              <tbody id="sortable-tracks">
                <% @tracks.each do |track| %>
                  <% zone_playlist_track = @zone_playlist.zone_playlist_tracks.find_by(track: track) %>
                  <tr draggable="true" data-track-id="<%= track.id %>" data-position="<%= zone_playlist_track.position %>" class="sortable-track">
                    <td style="text-align: center; cursor: grab; user-select: none;">
                      <span style="color: #888; font-size: 1.2em;">⋮⋮</span>
                    </td>
                    <td style="text-align: center;">
                      <span class="cyan-255-text position-number">#<%= zone_playlist_track.position %></span>
                    </td>
                    <td><strong><%= track.title %></strong></td>
                    <td><%= track.artist.name %></td>
                    <td><%= track.album&.name || "—" %></td>
                    <td style="text-align: center;">
                      <%= button_to "✗ Remove", remove_track_admin_zone_playlist_path(@zone_playlist, track_id: track.id),
                          method: :delete,
                          data: { confirm: "Remove '#{track.title}' from playlist?" },
                          class: "tui-button red-168",
                          style: "padding: 2px 10px; font-size: 0.9em; display: inline-block;" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
            <p style="color: #666; font-size: 1.2em;">No tracks in this playlist yet. Add some below!</p>
          </div>
        <% end %>
      </div>

      <!-- Add Tracks -->
      <div>
        <h3 style="color: #ccc; margin-bottom: 15px;">ADD TRACKS</h3>

        <% if @available_tracks.any? %>
          <div style="margin-bottom: 20px;">
            <label for="track-search" style="color: #888; display: block; margin-bottom: 8px;">
              SEARCH TRACKS :: Filter by track title, artist, or album
            </label>
            <input
              type="text"
              id="track-search"
              placeholder="Type to filter tracks..."
              style="width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace; font-size: 1em;"
            />
          </div>

          <div class="tui-window white-text" style="display: block; background: #0a0a0a; max-height: 500px; overflow-y: auto;">
            <table class="tui-table" style="width: 100%;">
              <thead>
                <tr>
                  <th style="text-align: left;">Track</th>
                  <th style="text-align: left;">Artist</th>
                  <th style="text-align: left;">Album</th>
                  <th style="text-align: center; width: 120px;">Action</th>
                </tr>
              </thead>
              <tbody>
                <% @available_tracks.each do |track| %>
                  <% already_in_playlist = @zone_playlist.tracks.exists?(track.id) %>
                  <tr class="track-row"
                      data-track-title="<%= track.title.downcase %>"
                      data-artist-name="<%= track.artist.name.downcase %>"
                      data-album-name="<%= track.album&.name&.downcase || '' %>">
                    <td><%= track.title %></td>
                    <td><%= track.artist.name %></td>
                    <td><%= track.album&.name || "—" %></td>
                    <td style="text-align: center;">
                      <% if already_in_playlist %>
                        <span style="color: #666;">✓ Added</span>
                      <% else %>
                        <%= button_to "➕ Add", add_track_admin_zone_playlist_path(@zone_playlist, track_id: track.id),
                            method: :post,
                            class: "tui-button purple-168",
                            style: "padding: 2px 10px; font-size: 0.9em; display: inline-block;" %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
            <p style="color: #666; font-size: 1.2em;">No tracks available in the database.</p>
          </div>
        <% end %>
      </div>
    </div>
  </fieldset>
</div>

<% if @tracks.any? %>
  <script nonce="<%= content_security_policy_nonce %>">
    // Drag and drop reordering for zone playlist tracks
    document.addEventListener('DOMContentLoaded', function() {
      const tbody = document.getElementById('sortable-tracks');
      if (!tbody) return;

      let draggedElement = null;
      let placeholder = null;

      // Create placeholder element
      function createPlaceholder() {
        const tr = document.createElement('tr');
        tr.className = 'drag-placeholder';
        tr.style.height = '40px';
        tr.style.background = 'rgba(168, 139, 250, 0.1)';
        tr.style.border = '2px dashed #a78bfa';
        const td = document.createElement('td');
        td.colSpan = 6;
        tr.appendChild(td);
        return tr;
      }

      // Handle drag start
      tbody.addEventListener('dragstart', function(e) {
        if (e.target.classList.contains('sortable-track')) {
          draggedElement = e.target;
          draggedElement.style.opacity = '0.4';
          draggedElement.style.cursor = 'grabbing';
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/html', draggedElement.innerHTML);
        }
      });

      // Handle drag over
      tbody.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';

        const target = e.target.closest('.sortable-track');
        if (target && target !== draggedElement && target !== placeholder) {
          const rect = target.getBoundingClientRect();
          const midpoint = rect.top + rect.height / 2;

          if (!placeholder) {
            placeholder = createPlaceholder();
          }

          if (e.clientY < midpoint) {
            target.parentNode.insertBefore(placeholder, target);
          } else {
            target.parentNode.insertBefore(placeholder, target.nextSibling);
          }
        }
      });

      // Handle drag end
      tbody.addEventListener('dragend', function(e) {
        if (draggedElement) {
          draggedElement.style.opacity = '';
          draggedElement.style.cursor = 'grab';

          if (placeholder && placeholder.parentNode) {
            placeholder.parentNode.insertBefore(draggedElement, placeholder);
            placeholder.remove();

            // Update positions and send to server
            updatePositions();
          }

          draggedElement = null;
          placeholder = null;
        }
      });

      // Update position numbers and send to server
      function updatePositions() {
        const rows = tbody.querySelectorAll('.sortable-track');
        const positions = {};

        rows.forEach((row, index) => {
          const trackId = row.dataset.trackId;
          const newPosition = index + 1;
          positions[trackId] = newPosition;

          // Update visual position number
          const positionSpan = row.querySelector('.position-number');
          if (positionSpan) {
            positionSpan.textContent = '#' + newPosition;
          }
        });

        // Send to server
        const playlistId = <%= @zone_playlist.id %>;
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;

        fetch(`/root/zone_playlists/${playlistId}/reorder_tracks`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
          },
          body: JSON.stringify({ positions: positions })
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Failed to save new order');
          }
          // Show success feedback
          const successMsg = document.createElement('div');
          successMsg.textContent = '✓ Track order updated';
          successMsg.style.cssText = 'position: fixed; top: 20px; right: 20px; background: #003300; border: 2px solid #00ff00; color: #00ff00; padding: 10px 20px; z-index: 9999;';
          document.body.appendChild(successMsg);
          setTimeout(() => successMsg.remove(), 2000);
        })
        .catch(err => {
          console.error('Failed to reorder tracks:', err);
          alert('Failed to save new track order. Please refresh the page.');
        });
      }
    });
  </script>
<% end %>

<% if @available_tracks.any? %>
  <script nonce="<%= content_security_policy_nonce %>">
    document.addEventListener('DOMContentLoaded', function() {
      const searchInput = document.getElementById('track-search');
      const trackRows = document.querySelectorAll('.track-row');

      function filterTracks() {
        const searchTerm = searchInput.value.toLowerCase().trim();

        trackRows.forEach(row => {
          const trackTitle = row.dataset.trackTitle || '';
          const artistName = row.dataset.artistName || '';
          const albumName = row.dataset.albumName || '';

          const matches = trackTitle.includes(searchTerm) ||
                         artistName.includes(searchTerm) ||
                         albumName.includes(searchTerm);

          row.style.display = matches ? '' : 'none';
        });
      }

      searchInput.addEventListener('input', filterTracks);

      // Focus search on Tab key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Tab' && !e.shiftKey && document.activeElement !== searchInput) {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });
    });
  </script>
<% end %>
