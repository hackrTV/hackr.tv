<%= form_with model: [:admin, zone_playlist], local: true do |f| %>
  <% if zone_playlist.errors.any? %>
    <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin-bottom: 20px;">
      <p class="red-255-text">⚠ <%= pluralize(zone_playlist.errors.count, "error") %> prevented this playlist from being saved:</p>
      <ul style="color: #ccc; margin: 10px 0 0 20px;">
        <% zone_playlist.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 20px;">
    <%= f.label :name, "Playlist Name", style: "display: block; color: #ccc; margin-bottom: 8px;" %>
    <%= f.text_field :name, style: "width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;", placeholder: "e.g., Resistance Ambience" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :description, "Description (optional)", style: "display: block; color: #ccc; margin-bottom: 8px;" %>
    <%= f.text_area :description, rows: 3, style: "width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;", placeholder: "Describe the mood or purpose of this playlist..." %>
  </div>

  <div style="display: flex; gap: 20px; margin-bottom: 20px;">
    <div style="flex: 1;">
      <%= f.label :crossfade_duration_ms, "Crossfade Duration (ms)", style: "display: block; color: #ccc; margin-bottom: 8px;" %>
      <%= f.number_field :crossfade_duration_ms, step: 100, min: 0, max: 15000, style: "width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;" %>
      <small style="color: #666; display: block; margin-top: 4px;">Suggested: 3000-6000ms</small>
    </div>

    <div style="flex: 1;">
      <%= f.label :default_volume, "Default Volume (0.0 - 1.0)", style: "display: block; color: #ccc; margin-bottom: 8px;" %>
      <%= f.number_field :default_volume, step: 0.01, min: 0.0, max: 1.0, style: "width: 100%; padding: 10px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;" %>
      <small style="color: #666; display: block; margin-top: 4px;">Suggested: 0.25-0.40</small>
    </div>
  </div>

  <div style="display: flex; gap: 10px; margin-top: 30px;">
    <%= f.submit zone_playlist.new_record? ? "Create Playlist" : "Update Playlist", class: "tui-button purple-168", style: "padding: 10px 30px;" %>
    <%= link_to "Cancel", zone_playlist.new_record? ? admin_zone_playlists_path : admin_zone_playlist_path(zone_playlist), class: "tui-button red-168", style: "padding: 10px 30px;" %>
  </div>
<% end %>
