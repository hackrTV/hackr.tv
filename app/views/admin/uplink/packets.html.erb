<div class="tui-window white-text admin-panel" style="display: block; max-width: 1600px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/uplink/packets :: MODERATE PACKETS</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Navigation -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px;">
        <%= link_to "← Uplink Dashboard", admin_uplink_index_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
      </div>

      <!-- Filters -->
      <div style="margin-bottom: 20px; background: #1a1a1a; padding: 15px; border: 1px solid #333;">
        <label style="color: #888; display: block; margin-bottom: 8px; font-weight: bold;">FILTER PACKETS</label>

        <%= form_with url: packets_admin_uplink_index_path, method: :get, local: true, style: "display: flex; flex-wrap: wrap; gap: 15px; align-items: end;" do |f| %>
          <!-- Channel Filter -->
          <div style="flex: 0 0 auto;">
            <label style="color: #666; display: block; margin-bottom: 5px; font-size: 0.9em;">Channel</label>
            <%= f.select :channel, ChatChannel.pluck(:name, :slug).unshift(["All Channels", ""]), { selected: params[:channel] }, style: "padding: 8px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;" %>
          </div>

          <!-- Status Filter -->
          <div style="flex: 0 0 auto;">
            <label style="color: #666; display: block; margin-bottom: 5px; font-size: 0.9em;">Status</label>
            <div style="display: flex; gap: 5px;">
              <%= link_to "All", packets_admin_uplink_index_path(channel: params[:channel], username: params[:username], search: params[:search]),
                  class: "tui-button #{params[:status].blank? ? 'cyan-168' : 'grey-168'}", style: "padding: 5px 12px;" %>
              <%= link_to "Active", packets_admin_uplink_index_path(status: 'active', channel: params[:channel], username: params[:username], search: params[:search]),
                  class: "tui-button #{params[:status] == 'active' ? 'green-168' : 'grey-168'}", style: "padding: 5px 12px;" %>
              <%= link_to "Dropped", packets_admin_uplink_index_path(status: 'dropped', channel: params[:channel], username: params[:username], search: params[:search]),
                  class: "tui-button #{params[:status] == 'dropped' ? 'red-168' : 'grey-168'}", style: "padding: 5px 12px;" %>
            </div>
          </div>

          <!-- Username Filter -->
          <div style="flex: 1 1 200px;">
            <label for="username" style="color: #666; display: block; margin-bottom: 5px; font-size: 0.9em;">Username</label>
            <%= f.text_field :username, value: params[:username], placeholder: "@username", style: "width: 100%; padding: 8px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;" %>
          </div>

          <!-- Content Search -->
          <div style="flex: 1 1 200px;">
            <label for="search" style="color: #666; display: block; margin-bottom: 5px; font-size: 0.9em;">Search</label>
            <%= f.text_field :search, value: params[:search], placeholder: "Search content...", style: "width: 100%; padding: 8px; background: #0a0a0a; border: 1px solid #444; color: #ccc; font-family: monospace;" %>
          </div>

          <div style="flex: 0 0 auto; display: flex; gap: 5px;">
            <%= f.submit "Apply Filters", class: "tui-button purple-168", style: "padding: 8px 20px;" %>
            <%= link_to "Clear", packets_admin_uplink_index_path, class: "tui-button grey-168", style: "padding: 8px 20px;" %>
          </div>
        <% end %>
      </div>

      <!-- Stats -->
      <div style="margin-bottom: 20px; color: #666;">
        <strong><%= @packets.count %></strong> packet<%= @packets.count == 1 ? '' : 's' %> found
      </div>

      <!-- Packets Table -->
      <% if @packets.any? %>
        <div class="tui-window white-text" style="display: block; background: #0a0a0a;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left; width: 10%;">Channel</th>
                <th style="text-align: left; width: 12%;">Hackr</th>
                <th style="text-align: left; width: 48%;">Content</th>
                <th style="text-align: center; width: 12%;">Timestamp</th>
                <th style="text-align: center; width: 18%;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @packets.each do |packet| %>
                <tr class="admin-table-row"<%= " style=\"background: #1a0000;\"".html_safe if packet.dropped %>>
                  <td>
                    <span style="color: #7c3aed;"><%= packet.chat_channel.name %></span>
                  </td>
                  <td>
                    <strong class="cyan-255-text">@<%= packet.grid_hackr.hackr_alias %></strong>
                  </td>
                  <td>
                    <div style="font-family: monospace; line-height: 1.5;">
                      <%= packet.dropped ? "[DROPPED]" : packet.content %>
                    </div>
                    <% if packet.dropped %>
                      <div style="margin-top: 8px;">
                        <span class="red-255-text">⚠ DROPPED</span>
                        <small style="color: #888;"><%= time_ago_in_words(packet.dropped_at) %> ago</small>
                      </div>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <small style="color: #888;">
                      <%= packet.created_at.strftime("%Y-%m-%d") %><br>
                      <%= packet.created_at.strftime("%H:%M") %>
                    </small>
                  </td>
                  <td style="text-align: center;">
                    <div style="display: flex; flex-direction: column; gap: 5px;">
                      <% if packet.dropped %>
                        <%= button_to "Restore", admin_restore_uplink_packet_path(packet), method: :post, class: "tui-button green-168", style: "padding: 2px 8px; font-size: 0.9em;" %>
                      <% else %>
                        <%= button_to "Drop", admin_drop_uplink_packet_path(packet), method: :post, data: { confirm: "Drop this packet?" }, class: "tui-button orange-168", style: "padding: 2px 8px; font-size: 0.9em;" %>
                      <% end %>
                      <%= button_to "Delete", admin_destroy_uplink_packet_path(packet), method: :delete, data: { confirm: "Permanently delete this packet? This cannot be undone!" }, class: "tui-button red-168", style: "padding: 2px 8px; font-size: 0.9em;" %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
          <p style="color: #666; font-size: 1.2em;">No packets match your filters.</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>
