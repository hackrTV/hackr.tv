<% content_for(:title) { "/root/overlays/lower-thirds/#{@lower_third.slug}/edit :: Edit Lower Third" } %>

<div class="tui-window cyan-168 white-text" style="display: block; max-width: 800px; margin: 30px auto;">
  <fieldset class="cyan-168-border">
    <legend class="center">/root/overlays/lower-thirds/<%= @lower_third.slug %>/edit :: EDIT LOWER THIRD</legend>

    <% if flash[:error] %>
      <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin-bottom: 20px;">
        <p class="red-255-text" style="margin: 0;">&#10007; ERROR</p>
        <p class="white-text" style="margin: 5px 0 0;"><%= flash[:error] %></p>
      </div>
    <% end %>

    <div style="margin-bottom: 30px; display: flex; gap: 10px;">
      <%= link_to "< Back to Lower Thirds", admin_overlay_lower_thirds_path, class: "tui-button green-168" %>
      <%= link_to "Preview", overlay_lower_third_path(slug: @lower_third.slug), target: "_blank", class: "tui-button purple-168" %>
    </div>

    <%= form_with model: [:admin, @lower_third], local: true do |form| %>
      <%= render "form", form: form %>

      <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
        <%= form.submit "Update Lower Third", class: "tui-button cyan-168" %>
        <%= link_to "Cancel", admin_overlay_lower_thirds_path, class: "tui-button red-168", style: "margin-left: 10px;" %>
      </div>
    <% end %>

    <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #333;">
      <h3 class="cyan-255-text" style="margin-bottom: 15px;">[:: OVERLAY URL ::]</h3>
      <p style="margin: 0;">
        <code class="cyan-168-text"><%= overlay_lower_third_url(slug: @lower_third.slug) %></code>
      </p>
    </div>

  </fieldset>
</div>

<div style="max-width: 800px; margin: 20px auto;">
  <%= button_to "Delete Lower Third", admin_overlay_lower_third_path(@lower_third),
      method: :delete,
      data: { confirm: "Delete '#{@lower_third.name}'?" },
      class: "tui-button red-168" %>
</div>
