<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <div>
    <%= form.label :name, "NAME *", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :name, class: "tui-input", style: "width: 100%;", placeholder: "e.g., XERAEN" %>
  </div>
  <div>
    <%= form.label :slug, "SLUG (auto-generated if blank)", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :slug, class: "tui-input", style: "width: 100%;", placeholder: "auto-generated" %>
  </div>
</div>

<div style="margin-bottom: 20px;">
  <%= form.label :primary_text, "PRIMARY TEXT *", style: "display: block; color: #888; margin-bottom: 5px;" %>
  <%= form.text_field :primary_text, class: "tui-input", style: "width: 100%;", placeholder: "Main text displayed" %>
</div>

<div style="margin-bottom: 20px;">
  <%= form.label :secondary_text, "SECONDARY TEXT", style: "display: block; color: #888; margin-bottom: 5px;" %>
  <%= form.text_field :secondary_text, class: "tui-input", style: "width: 100%;", placeholder: "Subtitle or description (optional)" %>
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px;">
  <div>
    <%= form.label :logo_url, "LOGO URL", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :logo_url, class: "tui-input", style: "width: 100%;", placeholder: "https://... (optional)" %>
  </div>
  <div>
    <%= form.label :active, "STATUS", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.select :active, [["Active", true], ["Inactive", false]], {}, class: "tui-input", style: "width: 100%;" %>
  </div>
</div>
