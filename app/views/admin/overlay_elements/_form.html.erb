<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <div>
    <%= form.label :name, "NAME *", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :name, class: "tui-input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.label :slug, "SLUG (auto-generated if blank)", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.text_field :slug, class: "tui-input", style: "width: 100%;", placeholder: "auto-generated" %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <div>
    <%= form.label :element_type, "ELEMENT TYPE *", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.select :element_type, OverlayElement::ELEMENT_TYPES.map { |t| [t, t] }, {}, class: "tui-input", style: "width: 100%;" %>
  </div>
  <div>
    <%= form.label :active, "STATUS", style: "display: block; color: #888; margin-bottom: 5px;" %>
    <%= form.select :active, [["Active", true], ["Inactive", false]], {}, class: "tui-input", style: "width: 100%;" %>
  </div>
</div>

<div style="background: #1a1a1a; padding: 15px; border: 1px dashed #333; margin-bottom: 20px;">
  <p style="color: #888; margin: 0 0 10px;">Element Type Reference:</p>
  <ul style="color: #666; margin: 0; padding-left: 20px;">
    <li><code>now_playing</code> - Shows current playing track</li>
    <li><code>pulsewire_feed</code> - Live PulseWire posts</li>
    <li><code>grid_activity</code> - THE PULSE GRID online users</li>
    <li><code>alert</code> - Alert/notification display</li>
    <li><code>lower_third</code> - Lower third graphics</li>
    <li><code>codex_entry</code> - Codex wiki entry display</li>
    <li><code>ticker_top</code> / <code>ticker_bottom</code> - Scrolling text tickers</li>
  </ul>
</div>
