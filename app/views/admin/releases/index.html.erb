<div class="tui-window white-text admin-panel" style="display: block; max-width: 1400px; margin: 30px auto; padding: 20px;">
  <fieldset class="admin-panel-border">
    <legend class="center">/root/releases :: MANAGE RELEASES</legend>

    <div style="padding: 20px;">
      <!-- Flash Messages -->
      <% if flash[:success] %>
        <div style="background: #003300; border: 2px solid #00ff00; padding: 15px; margin: 20px 0;">
          <p class="green-255-text">✓ SUCCESS</p>
          <p class="white-text"><%= flash[:success] %></p>
        </div>
      <% end %>

      <% if flash[:error] %>
        <div style="background: #330000; border: 2px solid #ff0000; padding: 15px; margin: 20px 0;">
          <p class="red-255-text">⚠ ERROR</p>
          <p class="white-text"><%= flash[:error] %></p>
        </div>
      <% end %>

      <!-- Navigation -->
      <div style="margin-bottom: 20px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
        <%= link_to "← Dashboard", admin_root_path, class: "tui-button green-168", style: "padding: 8px 20px;" %>
      </div>

      <!-- Releases Table -->
      <% if @releases.any? %>
        <div class="tui-window white-text" style="display: block; background: #0a0a0a; margin-top: 20px;">
          <table class="tui-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: center; width: 60px;">Cover</th>
                <th style="text-align: left;">Release</th>
                <th style="text-align: left;">Artist</th>
                <th style="text-align: left;">Type</th>
                <th style="text-align: center;">Release Date</th>
                <th style="text-align: center;">Tracks</th>
                <th style="text-align: center;">Status</th>
                <th style="text-align: center; width: 140px;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @releases.each do |release| %>
                <tr class="admin-table-row">
                  <td style="text-align: center; padding: 5px;">
                    <%= link_to edit_admin_release_path(release) do %>
                      <% if release.cover_image.attached? %>
                        <%= image_tag release.cover_thumbnail, style: "width: 50px; height: 50px; object-fit: cover; border: 1px solid #333;" %>
                      <% else %>
                        <div style="width: 50px; height: 50px; background: #1a1a1a; border: 1px solid #333; display: flex; align-items: center; justify-content: center; font-size: 0.7em; color: #666;">
                          NO IMG
                        </div>
                      <% end %>
                    <% end %>
                  </td>
                  <td>
                    <%= link_to edit_admin_release_path(release), style: "color: #0ff; text-decoration: none;" do %>
                      <strong><%= release.name %></strong>
                      <div style="font-family: monospace; color: #888; font-size: 0.85em;">/<%= release.slug %></div>
                    <% end %>
                  </td>
                  <td><%= release.artist.name %></td>
                  <td style="color: #888;"><%= release.release_type&.titleize || "—" %></td>
                  <td style="text-align: center; color: #888;">
                    <%= release.release_date&.strftime("%Y-%m-%d") || "TBA" %>
                  </td>
                  <td style="text-align: center;"><%= release.tracks.count %></td>
                  <td style="text-align: center;">
                    <% if release.coming_soon %>
                      <span style="color: #a855f7; font-size: 0.85em;">INCOMING</span>
                    <% else %>
                      <span style="color: #4ade80; font-size: 0.85em;">LIVE</span>
                    <% end %>
                  </td>
                  <td style="text-align: center;">
                    <%= link_to "Edit", edit_admin_release_path(release), class: "tui-button cyan-168", style: "padding: 4px 12px; font-size: 0.85em;" %>
                    <%= button_to "Delete", admin_release_path(release), method: :delete,
                        class: "tui-button red-168",
                        style: "padding: 4px 12px; font-size: 0.85em; display: inline;",
                        form: { class: "delete-release-form", data: { release_slug: release.slug } } %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div style="padding: 40px; text-align: center; background: #1a1a1a; border: 1px solid #333;">
          <p style="color: #666; font-size: 1.2em;">No releases yet.</p>
        </div>
      <% end %>
    </div>
  </fieldset>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.delete-release-form').forEach(function(form) {
      form.addEventListener('submit', function(e) {
        var slug = form.dataset.releaseSlug;
        var input = prompt('Type "' + slug + '" to confirm deletion:');
        if (input !== slug) {
          e.preventDefault();
          if (input !== null) alert('Slug did not match. Deletion cancelled.');
        }
      });
    });
  });
</script>
