<style>
  .terminal-container {
    background: #0a0a0a;
    color: #33cc33;
    font-family: 'Courier New', Courier, monospace;
    padding: 20px;
    margin: 20px;
    border: 2px solid #33aa33;
    border-radius: 5px;
    min-height: 500px;
    max-width: 1200px;
    box-shadow: 0 0 15px rgba(51, 170, 51, 0.2);
  }

  .terminal-output {
    white-space: pre-wrap;
    line-height: 1.6;
  }

  .terminal-cursor {
    display: inline-block;
    width: 10px;
    height: 18px;
    background: #33cc33;
    animation: blink 1s infinite;
    margin-left: 2px;
  }

  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .terminal-link {
    color: #4db8e8;
    text-decoration: underline;
  }

  .terminal-link:hover {
    color: #66ccff;
  }

  .terminal-prompt {
    color: #5cd65c;
    font-weight: bold;
  }

  .terminal-header {
    color: #5cb3cc;
  }
</style>

<div class="terminal-container">
  <div id="terminal-output" class="terminal-output"></div>
  <span class="terminal-cursor" id="cursor"></span>
</div>

<script>
  (function() {
    const output = document.getElementById('terminal-output');
    const cursor = document.getElementById('cursor');

    const lines = [
      { text: '════════════════════════════════════════════════════════════════', delay: 0 },
      { text: '  HACKR.TV BROADCAST SYSTEM v3.14.1592', delay: 300, class: 'terminal-header' },
      { text: '  INITIALIZING TRANSMISSION...', delay: 200 },
      { text: '════════════════════════════════════════════════════════════════', delay: 100 },
      { text: '', delay: 300 },
      { text: '> SYSTEM STATUS: ONLINE', delay: 500, class: 'terminal-prompt' },
      { text: '> YEAR: <%= Time.now.year %> (Origin Point)', delay: 200, class: 'terminal-prompt' },
      { text: '> SIGNAL RANGE: <%= Time.now.year %> - <%= Time.now.year + 100 %>', delay: 200, class: 'terminal-prompt' },
      { text: '', delay: 500 },
      { text: 'Welcome to hackr.tv - the multimedia resistance platform broadcasting', delay: 100 },
      { text: 'cyberpunk transmissions across time and space from <%= Time.now.year + 100 %>.', delay: 100 },
      { text: '', delay: 500 },
      { text: '─────────────────────────────────────────────────────────────────', delay: 200 },
      { text: 'FEATURED ARTISTS:', delay: 300, class: 'terminal-header' },
      { text: '─────────────────────────────────────────────────────────────────', delay: 100 },
      { text: '', delay: 300 },
      { text: '[0] <%= link_to "The.CyberPul.se", thecyberpulse_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '    Flagship Standard Bearers of the Hackrs of CyberSpace,', delay: 100 },
      { text: '    sending pirate broadcasts across time and space', delay: 100 },
      { text: '', delay: 200 },
      { text: '[1] <%= link_to "XERAEN", xeraen_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '    Trans-Temporal Operations from the future', delay: 100 },
      { text: '', delay: 200 },
      { text: '[2] <%= link_to "System Rot", system_rot_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '    Street-level resistance', delay: 100 },
      { text: '', delay: 200 },
      { text: '[3] <%= link_to "Wavelength Zero", wavelength_zero_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '    Signal disruption collective', delay: 100 },
      { text: '', delay: 200 },
      { text: '[4] <%= link_to "Voiceprint", voiceprint_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '    Archival resistance records', delay: 100 },
      { text: '', delay: 200 },
      { text: '[5] <%= link_to "Temporal Blue Drift", temporal_blue_drift_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '    Love letters across time', delay: 100 },
      { text: '', delay: 500 },
      { text: '─────────────────────────────────────────────────────────────────', delay: 200 },
      { text: 'PLATFORM SERVICES:', delay: 300, class: 'terminal-header' },
      { text: '─────────────────────────────────────────────────────────────────', delay: 100 },
      { text: '', delay: 300 },
      { text: '[FM] <%= link_to "hackr.fm", fm_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '     Radio & music streaming platform', delay: 100 },
      { text: '', delay: 200 },
      { text: '[GRID] <%= link_to "THE PULSE GRID", grid_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '       Text-based multiplayer game', delay: 100 },
      { text: '', delay: 200 },
      { text: '[LOGS] <%= link_to "Hackr Logs", hackr_logs_path, class: "terminal-link" %>', delay: 200, html: true },
      { text: '       Updates from the resistance', delay: 100 },
      { text: '', delay: 500 },
      { text: '════════════════════════════════════════════════════════════════', delay: 200 },
      { text: '  TRANSMISSION READY. SELECT YOUR DESTINATION.', delay: 100 },
      { text: '════════════════════════════════════════════════════════════════', delay: 100 },
      { text: '', delay: 100 },
      { text: '> _', delay: 0, class: 'terminal-prompt', keepCursor: true }
    ];

    let lineIndex = 0;
    let charIndex = 0;
    let currentLine = '';
    let typingSpeed = 8; // ms per character (lower = faster)
    let isTyping = true;
    let timeoutId = null;

    // Skip animation on any keypress
    function skipAnimation() {
      if (!isTyping) return;

      isTyping = false;
      if (timeoutId) clearTimeout(timeoutId);

      // Display all remaining lines immediately
      output.innerHTML = '';
      lines.forEach(line => {
        let lineElement = document.createElement('div');
        if (line.html) {
          lineElement.innerHTML = line.text;
        } else {
          lineElement.textContent = line.text;
        }
        if (line.class) {
          lineElement.className = line.class;
        }
        output.appendChild(lineElement);
      });

      cursor.style.display = 'none';
      window.scrollTo(0, document.body.scrollHeight);
    }

    // Listen for any keypress
    document.addEventListener('keydown', skipAnimation, { once: true });

    function typeWriter() {
      if (!isTyping) return;
      if (lineIndex < lines.length) {
        const line = lines[lineIndex];

        if (charIndex === 0 && line.delay > 0) {
          timeoutId = setTimeout(typeWriter, line.delay);
          charIndex++;
          return;
        }

        if (charIndex <= line.text.length) {
          currentLine = line.text.substring(0, charIndex);

          let lineElement;
          if (line.html) {
            lineElement = document.createElement('div');
            lineElement.innerHTML = currentLine;
            if (line.class) {
              lineElement.className = line.class;
            }
          } else {
            lineElement = document.createElement('div');
            lineElement.textContent = currentLine;
            if (line.class) {
              lineElement.className = line.class;
            }
          }

          // Remove the last line if we're still typing it
          if (output.lastChild && charIndex > 1) {
            output.removeChild(output.lastChild);
          }

          output.appendChild(lineElement);

          // Scroll to bottom
          window.scrollTo(0, document.body.scrollHeight);

          charIndex++;
          timeoutId = setTimeout(typeWriter, typingSpeed);
        } else {
          // Move to next line
          lineIndex++;
          charIndex = 0;
          timeoutId = setTimeout(typeWriter, 50);
        }
      } else {
        // Hide cursor when done
        isTyping = false;
        cursor.style.display = 'none';
      }
    }

    // Start typing after a short delay
    setTimeout(typeWriter, 500);
  })();
</script>
