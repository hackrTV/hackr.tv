#!/usr/bin/env bash
# Connect to Rails database, development by default, use `ENV` to set.

# Get the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Get the project root (parent of bin directory)
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Default to development environment
ENV="${1:-development}"

# Construct the database path
DB_PATH="$PROJECT_ROOT/storage/${ENV}.sqlite3"

# Check if the database file exists
if [ ! -f "$DB_PATH" ]; then
  echo "Error: Database file not found at $DB_PATH"
  echo "Usage: $0 [environment]"
  echo "  environment: development (default), test, production, etc."
  exit 1
fi

# Connect to the database using the best available client
echo "Connecting to $ENV database at $DB_PATH"
if command -v usql &> /dev/null; then
  usql "sqlite3://$DB_PATH"
elif command -v litecli &> /dev/null; then
  litecli --auto-vertical-output "$DB_PATH"
else
  sqlite3 "$DB_PATH"
fi
